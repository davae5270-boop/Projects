:root {
    --primary: #6C3CE1;
    --primary-dark: #5A2DBF;
    --primary-light: #8B6BE8;
    --secondary: #FF6B6B;
    --success: #00C853;
    --warning: #FFD600;
    --danger: #FF1744;
    --dark: #0A0A1A;
    --darker: #050510;
    --glass: rgba(255,255,255,0.05);
    --glass-border: rgba(255,255,255,0.06);
    --text: #FFFFFF;
    --text-secondary: rgba(255,255,255,0.7);
    --text-muted: rgba(255,255,255,0.3);
    --shadow: 0 8px 32px rgba(0,0,0,0.4);
    --radius: 16px;
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: 'Inter', sans-serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
}

/* ===== SIDEBAR ===== */
.sidebar {
    position: fixed;
    left: 0;
    top: 0;
    height: 100vh;
    width: 270px;
    background: rgba(5,5,16,0.95);
    backdrop-filter: blur(20px);
    border-right: 1px solid var(--glass-border);
    padding: 24px 16px;
    overflow-y: auto;
    z-index: 100;
    transition: transform 0.3s ease;
}
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 10px; }

.sidebar-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    margin-bottom: 32px;
}
.sidebar-brand .logo { font-size: 28px; }
.sidebar-brand .brand-text {
    font-size: 20px;
    font-weight: 800;
    background: linear-gradient(135deg, #fff, var(--primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
.sidebar-brand .brand-sub { font-size: 11px; color: var(--text-secondary); }

.sidebar-menu { list-style: none; padding: 0; }
.sidebar-menu .menu-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    padding: 16px 12px 8px;
}
.sidebar-menu li a {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 11px 16px;
    border-radius: 12px;
    color: var(--text-secondary);
    text-decoration: none;
    transition: var(--transition);
    font-weight: 500;
    font-size: 14px;
}
.sidebar-menu li a:hover { background: var(--glass); color: #fff; }
.sidebar-menu li a.active {
    background: linear-gradient(135deg, rgba(108,60,225,0.2), rgba(108,60,225,0.05));
    color: #fff;
    border: 1px solid rgba(108,60,225,0.2);
}
.sidebar-menu li a i { width: 20px; text-align: center; }

/* ===== MAIN ===== */
.main-content {
    margin-left: 270px;
    padding: 24px 32px;
    min-height: 100vh;
    position: relative;
    z-index: 1;
}

/* ===== TOPBAR ===== */
.topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0 20px;
    border-bottom: 1px solid var(--glass-border);
    margin-bottom: 32px;
}
.topbar-left { display: flex; align-items: center; gap: 16px; }
.sidebar-toggle {
    background: var(--glass);
    border: 1px solid var(--glass-border);
    color: #fff;
    padding: 10px 14px;
    border-radius: 10px;
    cursor: pointer;
    font-size: 18px;
    transition: var(--transition);
    display: none;
}
.sidebar-toggle:hover { background: rgba(255,255,255,0.1); }
.page-title {
    font-size: 24px;
    font-weight: 700;
    background: linear-gradient(135deg, #fff, var(--primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.topbar-right .user-info {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--glass);
    padding: 8px 16px 8px 12px;
    border-radius: 30px;
    border: 1px solid var(--glass-border);
}
.user-info .avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
}
.user-info .user-name { font-size: 14px; font-weight: 600; }
.user-info .user-balance { display: flex; gap: 6px; font-size: 13px; }
.user-info .balance-label { color: var(--text-secondary); }
.user-info .balance-value { font-weight: 600; color: var(--primary-light); }

/* ===== HERO ===== */
.hero-section {
    background: linear-gradient(135deg, rgba(108,60,225,0.1), rgba(108,60,225,0.02));
    border: 1px solid rgba(108,60,225,0.1);
    border-radius: var(--radius);
    padding: 48px 40px;
    margin-bottom: 32px;
    text-align: center;
}
.hero-content { max-width: 900px; margin: 0 auto; }
.hero-badge {
    display: inline-block;
    padding: 6px 20px;
    background: rgba(108,60,225,0.15);
    border: 1px solid rgba(108,60,225,0.2);
    border-radius: 30px;
    font-size: 13px;
    font-weight: 600;
    color: var(--primary-light);
    margin-bottom: 16px;
}
.hero-content h1 {
    font-size: 36px;
    font-weight: 800;
    margin-bottom: 12px;
    background: linear-gradient(135deg, #fff, var(--primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
.hero-content p {
    color: var(--text-secondary);
    font-size: 16px;
    max-width: 600px;
    margin: 0 auto 24px;
    line-height: 1.6;
}
.hero-buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
    flex-wrap: wrap;
}
.btn-hero { padding: 14px 36px; font-size: 16px; border-radius: 12px; }

.hero-features {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    border-top: 1px solid var(--glass-border);
    padding-top: 24px;
}
.hero-feature {
    text-align: center;
    padding: 12px;
}
.hero-feature .feature-icon {
    font-size: 24px;
    color: var(--primary-light);
    margin-bottom: 4px;
}
.hero-feature span {
    display: block;
    font-weight: 600;
    font-size: 14px;
}
.hero-feature small {
    color: var(--text-secondary);
    font-size: 12px;
}

/* ===== STATS ===== */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
}
.stat-card {
    background: var(--glass);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    padding: 20px 24px;
    text-align: center;
}
.stat-card .stat-value { font-size: 24px; font-weight: 700; }
.stat-card .stat-label { color: var(--text-secondary); font-size: 13px; }

/* ===== FEATURES ===== */
.features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
}
.feature-card {
    background: var(--glass);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    padding: 24px;
    text-align: center;
    transition: var(--transition);
}
.feature-card:hover { transform: translateY(-4px); border-color: rgba(108,60,225,0.25); box-shadow: var(--shadow); }
.feature-card .feature-icon { font-size: 32px; color: var(--primary-light); margin-bottom: 12px; }
.feature-card h3 { font-size: 16px; margin-bottom: 4px; }
.feature-card p { color: var(--text-secondary); font-size: 13px; margin-bottom: 12px; }
.feature-card .feature-btn {
    color: var(--primary-light);
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
}
.feature-card .feature-btn:hover { text-decoration: underline; }

/* ===== CARDS ===== */
.card {
    background: var(--glass);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 24px;
}
.card .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
}
.card .card-header h3 { font-size: 18px; font-weight: 600; }
.card .card-header .action-btn {
    background: var(--glass);
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 12px;
    cursor: pointer;
    text-decoration: none;
    transition: var(--transition);
}
.card .card-header .action-btn:hover { background: var(--primary); color: #fff; }

/* ===== TABLE ===== */
.table-wrapper { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; }
table thead th {
    text-align: left;
    padding: 12px 16px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--glass-border);
}
table tbody td {
    padding: 12px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    font-size: 14px;
    color: var(--text-secondary);
}
table tbody tr:hover { background: rgba(255,255,255,0.02); }

/* ===== STATUS BADGE ===== */
.status-badge {
    padding: 4px 14px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    display: inline-block;
}
.status-badge.pending { background: rgba(255,214,0,0.15); color: var(--warning); }
.status-badge.approved { background: rgba(0,200,83,0.15); color: var(--success); }
.status-badge.rejected { background: rgba(255,23,68,0.15); color: var(--danger); }

/* ===== GRID ===== */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
@media (max-width: 768px) { .grid-2, .grid-3 { grid-template-columns: 1fr; } }

/* ===== FORM ===== */
.form-group { margin-bottom: 16px; }
.form-group label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 6px;
}
.form-control {
    width: 100%;
    padding: 12px 16px;
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    color: #fff;
    font-size: 14px;
    transition: var(--transition);
    font-family: 'Inter', sans-serif;
}
.form-control:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(108,60,225,0.1);
}
.form-control::placeholder { color: var(--text-muted); }
select.form-control option { background: var(--darker); color: #fff; }

/* ===== BUTTONS ===== */
.btn {
    padding: 12px 28px;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: var(--transition);
    font-family: 'Inter', sans-serif;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
}
.btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: #fff;
    box-shadow: 0 4px 20px rgba(108,60,225,0.3);
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 40px rgba(108,60,225,0.4); }
.btn-success {
    background: linear-gradient(135deg, var(--success), #009624);
    color: #fff;
}
.btn-danger {
    background: linear-gradient(135deg, var(--danger), #c62828);
    color: #fff;
}
.btn-outline {
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text);
}
.btn-outline:hover { background: var(--glass); }
.btn-sm { padding: 6px 16px; font-size: 12px; }
.btn-block { width: 100%; justify-content: center; }

/* ===== TOAST ===== */
.toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 10px;
}
.toast {
    padding: 14px 20px;
    border-radius: 12px;
    background: rgba(5,5,16,0.95);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow);
    color: #fff;
    font-size: 14px;
    min-width: 280px;
    animation: slideIn 0.4s ease;
}
.toast.success { border-left: 4px solid var(--success); }
.toast.error { border-left: 4px solid var(--danger); }
@keyframes slideIn {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
}

/* ===== SLOT ===== */
.slot-machine {
    background: var(--darker);
    border-radius: var(--radius);
    padding: 24px;
    text-align: center;
    border: 1px solid var(--glass-border);
    margin-bottom: 24px;
}
.slot-machine .reels {
    display: flex;
    justify-content: center;
    gap: 24px;
    font-size: 56px;
    padding: 20px;
    background: rgba(0,0,0,0.3);
    border-radius: 12px;
}
.slot-machine .slot-result { font-size: 18px; font-weight: 600; margin-top: 12px; }
.slot-machine .slot-bet { color: var(--text-secondary); margin-top: 4px; }

.bet-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
    justify-content: center;
}
.bet-options .bet-btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--glass-border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: var(--transition);
    font-size: 13px;
    font-weight: 500;
}
.bet-options .bet-btn:hover { border-color: var(--primary); color: #fff; }
.bet-options .bet-btn.active {
    background: var(--primary);
    border-color: var(--primary);
    color: #fff;
}

/* ===== MOBILE ===== */
@media (max-width: 768px) {
    .sidebar { transform: translateX(-100%); }
    .sidebar.open { transform: translateX(0); }
    .main-content { margin-left: 0; padding: 16px; }
    .sidebar-toggle { display: block; }
    .hero-content h1 { font-size: 24px; }
    .hero-features { grid-template-columns: repeat(3, 1fr); }
    .hero-buttons { flex-direction: column; align-items: center; }
    .features-grid { grid-template-columns: 1fr 1fr; }
    .topbar { flex-wrap: wrap; }
    .topbar-right { width: 100%; }
    .topbar-right .user-info { width: 100%; justify-content: space-between; }
}
@media (max-width: 480px) {
    .hero-features { grid-template-columns: repeat(2, 1fr); gap: 8px; }
    .features-grid { grid-template-columns: 1fr; }
    .hero-section { padding: 24px 16px; }
    .hero-content h1 { font-size: 20px; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .slot-machine .reels { font-size: 36px; gap: 12px; padding: 16px; }
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--darker); }
::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 10px; }