{% extends "base.html" %}

{% block title %}Admin Panel - DavaOFC{% endblock %}
{% block page_title %}👑 Super Admin Dashboard{% endblock %}

{% block content %}
<!-- ==================== AREA 1: TOP STATISTICS CARDS ==================== -->
<div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 15px; margin-bottom: 25px;">
    <div class="card stat-card" style="text-align: center; padding: 20px; border-left: 4px solid #a855f7; background: #111122; border-radius: 8px;">
        <span style="font-size: 26px; font-weight: bold; color: #a855f7;">{{ total_users|default(7) }}</span>
        <div style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); margin-top: 5px; letter-spacing: 1px;">Total Users</div>
    </div>
    <div class="card stat-card" style="text-align: center; padding: 20px; border-left: 4px solid #eab308; background: #111122; border-radius: 8px;">
        <span style="font-size: 26px; font-weight: bold; color: #eab308;">{{ total_orders|default(16) }}</span>
        <div style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); margin-top: 5px; letter-spacing: 1px;">Total Orders</div>
    </div>
    <div class="card stat-card" style="text-align: center; padding: 20px; border-left: 4px solid #ef4444; background: #111122; border-radius: 8px;">
        <span style="font-size: 26px; font-weight: bold; color: #ef4444;">{{ pending_orders|length }}</span>
        <div style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); margin-top: 5px; letter-spacing: 1px;">Pending Orders</div>
    </div>
    <div class="card stat-card" style="text-align: center; padding: 20px; border-left: 4px solid #22c55e; background: #111122; border-radius: 8px;">
        <span style="font-size: 26px; font-weight: bold; color: #22c55e;">{{ pending_deposits|length }}</span>
        <div style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); margin-top: 5px; letter-spacing: 1px;">Total Deposits</div>
    </div>
</div>

<!-- ==================== AREA 2: SYSTEM CONFIGURATION PANEL ==================== -->
<div class="settings-grid-layout" style="display: grid; grid-template-columns: 1fr; gap: 25px; margin-bottom: 25px;">
    <div class="card" style="background: #111122; border-radius: 8px; border: 1px solid #2d2d44;">
        <div class="card-header" style="padding: 15px 20px; border-bottom: 1px solid #2d2d44; display: flex; justify-content: space-between; align-items: center;">
            <h3 style="margin: 0; color: #fff;"><i class="fas fa-sliders-h" style="color: #a855f7;"></i> Configuration Panel</h3>
            <button class="btn btn-secondary" onclick="window.location.reload()" style="background: #2d2d44; border: none; padding: 6px 12px; border-radius: 4px; color: #fff; cursor: pointer; font-size: 12px; font-weight: bold;">🔄 Refresh Data</button>
        </div>
        <div class="card-body" style="padding: 20px;">
            <form id="globalSettingsForm" onsubmit="saveGlobalSettings(event)">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 15px;">
                    <div>
                        <label style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); font-weight: 600;">Min Deposit</label>
                        <input type="number" name="min_deposit" value="{{ settings.min_deposit|default(10000) }}" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; margin-top: 5px; border-radius: 4px;">
                    </div>
                    <div>
                        <label style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); font-weight: 600;">Min Withdraw</label>
                        <input type="number" name="min_withdraw" value="{{ settings.min_withdraw|default(50000) }}" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; margin-top: 5px; border-radius: 4px;">
                    </div>
                    <div>
                        <label style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); font-weight: 600;">Withdraw Fee</label>
                        <input type="number" name="withdraw_fee" value="{{ settings.withdraw_fee|default(5000) }}" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; margin-top: 5px; border-radius: 4px;">
                    </div>
                    <div>
                        <label style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); font-weight: 600;">Profit Rate (%)</label>
                        <input type="number" step="0.01" name="profit_rate" value="{{ settings.profit_rate|default(0) }}" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; margin-top: 5px; border-radius: 4px;">
                    </div>
                    <div>
                        <label style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); font-weight: 600;">Profit Interval (Sec)</label>
                        <input type="number" name="profit_interval" value="{{ settings.profit_interval|default(300) }}" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; margin-top: 5px; border-radius: 4px;">
                    </div>
                    <div>
                        <label style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); font-weight: 600;">Maintenance Mode</label>
                        <select name="maintenance" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; margin-top: 5px; border-radius: 4px; cursor: pointer;">
                            <option value="off" {% if settings.maintenance == 'off' %}selected{% endif %}>🟢 Off (Website Open)</option>
                            <option value="on" {% if settings.maintenance == 'on' %}selected{% endif %}>🔴 On (Under Maintenance)</option>
                        </select>
                    </div>
                    <div>
                        <label style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); font-weight: 600;">Slot Min Bet</label>
                        <input type="number" name="slot_min_bet" value="{{ settings.slot_min_bet|default(400) }}" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; margin-top: 5px; border-radius: 4px;">
                    </div>
                    <div>
                        <label style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); font-weight: 600;">Slot Max Bet</label>
                        <input type="number" name="slot_max_bet" value="{{ settings.slot_max_bet|default(204800) }}" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; margin-top: 5px; border-radius: 4px;">
                    </div>
                    <div>
                        <label style="font-size: 11px; text-transform: uppercase; color: var(--text-secondary); font-weight: 600;">Referral Bonus</label>
                        <input type="number" name="referral_bonus" value="{{ settings.referral_bonus|default(400) }}" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; margin-top: 5px; border-radius: 4px;">
                    </div>
                    <div>
                        <label style="font-size: 11px; text-transform: uppercase; color: #22c55e; font-weight: bold;">💵 Harga USD (IDR)</label>
                        <input type="number" name="usd_to_idr" id="usdToIdrInput" oninput="liveUpdateKurs(this.value)" value="{{ settings.usd_to_idr|default(16000) }}" style="width: 100%; background: #141424; border: 1px solid #16a34a; padding: 10px; color: #22c55e; margin-top: 5px; border-radius: 4px; font-weight: bold;">
                        <span style="font-size: 11px; color: #22c55e; display: block; margin-top: 5px;">✍️ Live Preview: <strong id="liveKursText">Rp {{ "{:,.0f}".format(settings.usd_to_idr|default(16000)).replace(',', '.') }}</strong></span>
                    </div>
                </div>
                <button type="submit" class="btn btn-success" style="width: 100%; margin-top: 20px; padding: 12px; font-weight: bold; font-size: 14px; background: #22c55e; color: #fff; border: none; border-radius: 4px; cursor: pointer;">💾 Simpan Konfigurasi Sistem</button>
            </form>
        </div>
    </div>
</div>

<!-- ==================== AREA 3: RECENT ORDERS TABLE (FULL WIDTH) ==================== -->
<div class="card" style="background: #111122; border-radius: 8px; border: 1px solid #2d2d44; margin-bottom: 25px;">
    <div class="card-header" style="padding: 15px 20px; border-bottom: 1px solid #2d2d44; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
        <h3 style="margin: 0; color: #fff;"><i class="fas fa-list" style="color: #a855f7;"></i> Recent Orders ({{ pending_orders|length }})</h3>
        <input type="text" id="searchOrders" placeholder="Cari ID / Username..." onkeyup="filterTable('searchOrders', 'tableOrders')" style="background: #141424; border: 1px solid #2d2d44; padding: 6px 12px; color: #fff; border-radius: 4px; font-size: 13px;">
    </div>
    <div class="table-wrapper" style="overflow-x: auto;">
        <table id="tableOrders" style="width: 100%; border-collapse: collapse; min-width: 1000px;">
            <thead>
                <tr style="border-bottom: 1px solid #2d2d44; text-align: left; background: #141424;">
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">ID</th>
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">USER</th>
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">NAMA</th>
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">BANK</th>
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">REKENING TUJUAN</th>
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">USD</th>
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">FEE</th>
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">TOTAL</th>
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">STATUS</th>
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">PHOTO</th>
                    <th style="padding: 12px 15px; color: var(--text-secondary); font-size: 12px;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                {% for order in pending_orders %}
                <tr style="border-bottom: 1px solid #1a1a2e; font-size: 13px;">
                    <td style="padding: 12px 15px;"><code>{{ order.order_number }}</code></td>
                    <td style="padding: 12px 15px; color: #a855f7;">@{{ order.username }}</td>
                    <td style="padding: 12px 15px;">{{ order.full_name|default('-') }}</td>
                    <td style="padding: 12px 15px;">{{ order.bank_name }}</td>
                    <td style="padding: 12px 15px;"><code>{{ order.target_account|default('-') }}</code></td>
                    <td style="padding: 12px 15px;">${{ order.amount_usd|default('0.00') }}</td>
                    <td style="padding: 12px 15px; color: #ef4444;">Rp {{ "{:,.0f}".format(order.fee|default(0)).replace(',', '.') }}</td>
                    <td style="padding: 12px 15px; font-weight: bold; color: #22c55e;">Rp {{ "{:,.0f}".format(order.amount_idr).replace(',', '.') }}</td>
                    <td style="padding: 12px 15px;"><span class="status-badge pending" style="background: rgba(234, 179, 8, 0.1); color: #eab308; padding: 4px 8px; border-radius: 4px; font-size: 11px;">Pending</span></td>
                    <td style="padding: 12px 15px;">
                        {% if order.proof_photo %}
                        <a href="{{ order.proof_photo }}" target="_blank" style="color: #a855f7; text-decoration: underline;">Lihat Foto</a>
                        {% else %}
                        <span style="color: var(--text-secondary); font-size: 11px;">Tidak ada</span>
                        {% endif %}
                    </td>
                    <td style="padding: 12px 15px;">
                        <div style="display: flex; gap: 5px;">
                            <button class="btn btn-success btn-sm" onclick="approveOrder('{{ order.order_number }}')" style="cursor: pointer; background: #22c55e; border: none; padding: 5px 8px; border-radius: 4px; color: white; font-size: 11px;">✅ Approve</button>
                            <button class="btn btn-danger btn-sm" onclick="rejectOrder('{{ order.order_number }}')" style="cursor: pointer; background: #ef4444; border: none; padding: 5px 8px; border-radius: 4px; color: white; font-size: 11px;">❌ Reject</button>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="11" style="text-align: center; padding: 30px; color: var(--text-secondary);">Tidak ada order pending</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- ==================== AREA 4: SIDE-BY-SIDE PANELS (DEPOSITS & WITHDRAWS) ==================== -->
<div class="bottom-grid-layout" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); gap: 20px; margin-bottom: 25px;">
    
    <!-- PENDING DEPOSITS -->
    <div class="card" style="background: #111122; border-radius: 8px; border: 1px solid #2d2d44;">
        <div class="card-header" style="padding: 15px 20px; border-bottom: 1px solid #2d2d44; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
            <h3 style="margin: 0; color: #fff; font-size: 15px;"><i class="fas fa-arrow-down" style="color: #22c55e;"></i> Pending Deposits ({{ pending_deposits|length }})</h3>
            <input type="text" id="searchDeposits" placeholder="Cari..." onkeyup="filterTable('searchDeposits', 'tableDeposits')" style="background: #141424; border: 1px solid #2d2d44; padding: 4px 10px; color: #fff; border-radius: 4px; font-size: 12px; width: 150px;">
        </div>
        <div class="table-wrapper" style="overflow-x: auto;">
            <table id="tableDeposits" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid #2d2d44; text-align: left; background: #141424;">
                        <th style="padding: 10px 15px; color: var(--text-secondary); font-size: 12px;">ID Depo</th>
                        <th style="padding: 10px 15px; color: var(--text-secondary); font-size: 12px;">User</th>
                        <th style="padding: 10px 15px; color: var(--text-secondary); font-size: 12px;">Jumlah</th>
                        <th style="padding: 10px 15px; color: var(--text-secondary); font-size: 12px;">Status</th>
                        <th style="padding: 10px 15px; color: var(--text-secondary); font-size: 12px;">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    {% for dep in pending_deposits %}
                    <tr style="border-bottom: 1px solid #1a1a2e; font-size: 13px;">
                        <td style="padding: 10px 15px;"><code>{{ dep.dep_number }}</code></td>
                        <td style="padding: 10px 15px; color: #a855f7;">@{{ dep.username }}</td>
                        <td style="padding: 10px 15px; font-weight: bold; color: #22c55e;">Rp {{ "{:,.0f}".format(dep.amount).replace(',', '.') }}</td>
                        <td style="padding: 10px 15px;"><span class="status-badge pending" style="background: rgba(234, 179, 8, 0.1); color: #eab308; padding: 2px 6px; border-radius: 4px; font-size: 11px;">Pending</span></td>
                        <td style="padding: 10px 15px;">
                            <div style="display: flex; gap: 4px;">
                                <button class="btn btn-success btn-sm" onclick="approveDeposit('{{ dep.dep_number }}')" style="cursor: pointer; background: #22c55e; border: none; padding: 4px 8px; border-radius: 4px; color: white; font-size: 11px;">✅</button>
                                <button class="btn btn-danger btn-sm" onclick="rejectDeposit('{{ dep.dep_number }}')" style="cursor: pointer; background: #ef4444; border: none; padding: 4px 8px; border-radius: 4px; color: white; font-size: 11px;">❌</button>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" style="text-align: center; padding: 20px; color: var(--text-secondary); font-size: 13px;">Tidak ada deposit pending</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- PENDING WITHDRAWS -->
    <div class="card" style="background: #111122; border-radius: 8px; border: 1px solid #2d2d44;">
        <div class="card-header" style="padding: 15px 20px; border-bottom: 1px solid #2d2d44; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
            <h3 style="margin: 0; color: #fff; font-size: 15px;"><i class="fas fa-arrow-up" style="color: #ef4444;"></i> Pending Withdraws ({{ pending_withdraws|length }})</h3>
            <input type="text" id="searchWithdraws" placeholder="Cari..." onkeyup="filterTable('searchWithdraws', 'tableWithdraws')" style="background: #141424; border: 1px solid #2d2d44; padding: 4px 10px; color: #fff; border-radius: 4px; font-size: 12px; width: 150px;">
        </div>
        <div class="table-wrapper" style="overflow-x: auto;">
            <table id="tableWithdraws" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid #2d2d44; text-align: left; background: #141424;">
                        <th style="padding: 10px 15px; color: var(--text-secondary); font-size: 12px;">ID WD</th>
                        <th style="padding: 10px 15px; color: var(--text-secondary); font-size: 12px;">User</th>
                        <th style="padding: 10px 15px; color: var(--text-secondary); font-size: 12px;">Jumlah</th>
                        <th style="padding: 10px 15px; color: var(--text-secondary); font-size: 12px;">Tujuan</th>
                        <th style="padding: 10px 15px; color: var(--text-secondary); font-size: 12px;">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    {% for wd in pending_withdraws %}
                    <tr style="border-bottom: 1px solid #1a1a2e; font-size: 13px;">
                        <td style="padding: 10px 15px;"><code>{{ wd.wd_number }}</code></td>
                        <td style="padding: 10px 15px; color: #a855f7;">@{{ wd.username }}</td>
                        <td style="padding: 10px 15px; font-weight: bold; color: #ef4444;">Rp {{ "{:,.0f}".format(wd.amount).replace(',', '.') }}</td>
                        <td style="padding: 10px 15px;" title="{{ wd.destination }}">{{ wd.destination[:12] }}...</td>
                        <td style="padding: 10px 15px;">
                            <div style="display: flex; gap: 4px;">
                                <button class="btn btn-success btn-sm" onclick="approveWithdraw('{{ wd.wd_number }}')" style="cursor: pointer; background: #22c55e; border: none; padding: 4px 8px; border-radius: 4px; color: white; font-size: 11px;">✅</button>
                                <button class="btn btn-danger btn-sm" onclick="rejectWithdraw('{{ wd.wd_number }}')" style="cursor: pointer; background: #ef4444; border: none; padding: 4px 8px; border-radius: 4px; color: white; font-size: 11px;">❌</button>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" style="text-align: center; padding: 20px; color: var(--text-secondary); font-size: 13px;">Tidak ada withdraw pending</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ==================== AREA 5: MATRIX FEES & CRYPTO GATEWAYS (BOTTOM AREA) ==================== -->
<div class="settings-grid-layout" style="display: grid; grid-template-columns: 1fr; gap: 25px;">
    
    <!-- FEE MATRIX -->
    <div class="card" style="background: #111122; border-radius: 8px; border: 1px solid #2d2d44;">
        <div class="card-header">
            <h3 style="margin: 0; color: #fff; padding: 15px 20px; border-bottom: 1px solid #2d2d44;"><i class="fas fa-dollar-sign" style="color: #eab308;"></i> Fee Settings Matrix</h3>
        </div>
        <div class="card-body" style="padding: 20px;">
            <form id="feeSettingsForm" onsubmit="addFeeConfig(event)" style="margin-bottom: 20px;">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; align-items: end;">
                    <div>
                        <label style="font-size: 11px; color: var(--text-secondary);">Minimal Range (Rp)</label>
                        <input type="number" placeholder="0" name="fee_min" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; border-radius: 4px;" required>
                    </div>
                    <div>
                        <label style="font-size: 11px; color: var(--text-secondary);">Maximal Range (Rp)</label>
                        <input type="number" placeholder="50000" name="fee_max" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; border-radius: 4px;" required>
                    </div>
                    <div>
                        <label style="font-size: 11px; color: var(--text-secondary);">Nilai Potongan Fee (Rp)</label>
                        <input type="number" placeholder="2000" name="fee_val" style="width: 100%; background: #141424; border: 1px solid #2d2d44; padding: 10px; color: #fff; border-radius: 4px;" required>
                    </div>
                    <button type="submit" style="background: #a855f7; border: none; color: white; padding: 11px; cursor: pointer; border-radius: 4px; font-weight: bold; text-transform: uppercase; font-size: 11px; height: 38px;">➕ Tambah Rule</button>
                </div>
            </form>

            <div style="background: #141424; padding: 15px; border-radius: 6px; border: 1px solid #2d2d44;">
                <h4 style="margin: 0 0 10px 0; font-size: 13px; color: var(--text-secondary);">Daftar Fee Terpasang saat ini:</h4>
                <div id="feeMatrixContainer" style="display: flex; flex-direction: column; gap: 8px;">
                    {% for fee in active_fees|default([{'id':1, 'min':0, 'max':10000, 'val':1000}]) %}
                    <div style="display: flex; justify-content: space-between; align-items: center; background: #0c0c16; padding: 8px 12px; border-radius: 4px; border-left: 3px solid #a855f7;">
                        <span style="font-size: 12px;">Range: <strong>Rp {{ fee.min }}</strong> - <strong>Rp {{ fee.max }}</strong> → Potongan: <strong style="color: #ef4444;">Rp {{ fee.val }}</strong></span>
                        <button onclick="deleteFeeRule('{{ fee.id }}')" style="background: none; border: none; color: #ef4444; cursor: pointer;" title="Hapus rule ini">🗑️</button>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    <!-- CRYPTO WALLET MANAGEMENT -->
    <div class="card" style="background: #111122; border-radius: 8px; border: 1px solid #2d2d44;">
        <div class="card-header">
            <h3 style="margin: 0; color: #fff; padding: 15px 20px; border-bottom: 1px solid #2d2d44;"><i class="fas fa-wallet" style="color: #22c55e;"></i> Wallet Settings (Sistem Kripto)</h3>
        </div>
        <div class="card-body" style="padding: 20px;">
            <div class="wallets-list" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 15px; margin-bottom: 25px;">
                {% set default_wallets = [
                    ('BNB', '0x7a51cee3216Bd7E2d4C245a374bfFAA98858A298b'),
                    ('BTC', '1A1zP1eP5QGefi2DMPTfTL5SLmv7DivfNa'),
                    ('DOGE', 'DLfP6qoUd6wowJ1Wao4WZrFUEjanC8Pzvs'),
                    ('ETH', '0x7a51cee3216Bd7E2d4C245a374bfFAA98858A298b'),
                    ('SOL', 'So11111111111111111111111111111111111111112'),
                    ('USDT BEP-20', '0x7a51cee3216Bd7E2d4C245a374bfFAA98858A298b'),
                    ('USDT ERC-20', '0x7a51cee3216Bd7E2d4C245a374bfFAA98858A298b'),
                    ('USDT TRC-20', 'TM7ySbKFBUGRoDEs2snuttcJmV8qkFBRYx')
                ] %}
                
                {% for key, wallet in wallets.items()|default(default_wallets) %}
                {% set safe_key = key|replace(' ', '-')|replace('_', '-') %}
                <div id="wallet-card-{{ safe_key }}" style="background: #141424; padding: 15px; border-radius: 6px; border: 1px solid #2d2d44; position: relative;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <label style="color: #eab308; font-weight: bold; font-size: 12px; text-transform: uppercase;">{{ key }}</label>
                        <button onclick="removeCryptoAsset('{{ key }}')" style="background:none; border:none; color:#ef4444; font-size:12px; cursor:pointer;" title="Hapus Aset ini">❌ Hapus</button>
                    </div>
                    <div style="font-size: 11px; color: #a855f7; word-break: break-all; margin: 6px 0; background: #0c0c16; padding: 6px; border-radius: 4px;">{{ wallet }}</div>
                    <div style="display: flex; gap: 8px; margin-top: 10px;">
                        <input type="text" id="wallet-input-{{ safe_key }}" class="form-control" value="{{ wallet }}" style="flex: 1; background: #1a1a2e; border: 1px solid #2d2d44; padding: 8px; color: #fff; font-size: 12px; border-radius: 4px;">
                        <button class="btn btn-primary" onclick="updateWalletAddress('{{ key }}')" style="background: #2563eb; color: #fff; border: none; padding: 0 15px; border-radius: 4px; font-size: 11px; cursor: pointer; font-weight: bold;">Update</button>
                    </div>
                </div>
                {% endfor %}
            </div>
            
            <hr style="border-color: #2d2d44; margin: 20px 0;">
            
            <form id="addCryptoForm" onsubmit="addNewCryptoWallet(event)" style="background: #141424; padding: 15px; border-radius: 6px; border: 1px solid #2d2d44;">
                <h4 style="margin: 0 0 12px 0; color: #fff; font-size: 13px;"><i class="fas fa-plus-circle" style="color: #22c55e;"></i> Tambah Jaringan / Token Baru</h4>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
                    <input type="text" name="token_name" placeholder="Nama Token (Contoh: TRX, TON, XRP)" style="width: 100%; background: #111122; border: 1px solid #2d2d44; padding: 10px; color: #fff; border-radius: 4px;" required>
                    <input type="text" name="wallet_address" placeholder="Alamat Wallet Lengkap" style="width: 100%; background: #111122; border: 1px solid #2d2d44; padding: 10px; color: #fff; border-radius: 4px;" required>
                    <button type="submit" style="width: 100%; background: #22c55e; border: none; color: white; padding: 10px; cursor: pointer; border-radius: 4px; font-weight: bold; text-transform: uppercase; font-size: 11px;">🚀 Daftarkan Jaringan</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
// ==================== 1. FITUR SEARCH FILTER REALTIME ====================
function filterTable(inputId, tableId) {
    const input = document.getElementById(inputId);
    const filter = input.value.toUpperCase();
    const table = document.getElementById(tableId);
    const tr = table.getElementsByTagName("tr");

    for (let i = 1; i < tr.length; i++) {
        let match = false;
        const tds = tr[i].getElementsByTagName("td");
        for (let j = 0; j < tds.length - 1; j++) {
            if (tds[j] && tds[j].innerText.toUpperCase().indexOf(filter) > -1) {
                match = true;
                break;
            }
        }
        tr[i].style.display = match ? "" : "none";
    }
}

// Live update angka kurs USD ke Rp agar presisi secara real-time
function liveUpdateKurs(val) {
    const textElement = document.getElementById('liveKursText');
    if(!val) { textElement.innerText = "Rp 0"; return;}
    textElement.innerText = "Rp " + Number(val).toLocaleString('id-ID');
}

// ==================== 2. OPERATIONS JS (ORDERS, DEPO, WD) ====================
async function makePostRequest(url, payload, successMessage) {
    try {
        const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) {
            if (typeof showToast === "function") showToast(successMessage, 'success');
            else alert(successMessage);
            location.reload();
        } else {
            alert("Gagal: " + (data.message || "Terjadi kesalahan internal"));
        }
    } catch (err) {
        alert("Error Request: " + err.message);
    }
}

function approveOrder(id) {
    if (confirm(`Setujui pemrosesan ID Order: ${id}?`)) {
        makePostRequest('/api/admin/approve_order', { order_number: id }, 'Order berhasil disetujui!');
    }
}
function rejectOrder(id) {
    if (confirm(`Tolak ID Order: ${id}?`)) {
        makePostRequest('/api/admin/reject_order', { order_number: id }, 'Order berhasil ditolak!');
    }
}
function approveDeposit(id) {
    if (confirm(`Setujui saldo masuk untuk ID Depo: ${id}?`)) {
        makePostRequest('/api/admin/approve_deposit', { dep_number: id }, 'Deposit disetujui, saldo bertambah!');
    }
}
function rejectDeposit(id) {
    if (confirm(`Batalkan/Tolak ID Depo: ${id}?`)) {
        makePostRequest('/api/admin/reject_deposit', { dep_number: id }, 'Deposit ditolak!');
    }
}
function approveWithdraw(id) {
    if (confirm(`Konfirmasi penarikan sukses untuk ID WD: ${id}?`)) {
        makePostRequest('/api/admin/approve_withdraw', { wd_number: id }, 'Withdraw sukses diproses ke tujuan!');
    }
}
function rejectWithdraw(id) {
    if (confirm(`Kembalikan saldo dan tolak ID WD: ${id}?`)) {
        makePostRequest('/api/admin/reject_withdraw', { wd_number: id }, 'Withdraw dibatalkan!');
    }
}

// ==================== 3. CONFIG PANEL BACKEND API WORKERS ====================
async function saveGlobalSettings(e) {
    e.preventDefault();
    const formData = new FormData(e.target);
    const payload = Object.fromEntries(formData.entries());
    await makePostRequest('/api/admin/save_settings', payload, 'Konfigurasi sistem global berhasil diperbarui!');
}

async function addFeeConfig(e) {
    e.preventDefault();
    const formData = new FormData(e.target);
    const payload = Object.fromEntries(formData.entries());
    await makePostRequest('/api/admin/add_fee_matrix', payload, 'Aturan baru potongan Fee Matrix ditambahkan!');
}

async function deleteFeeRule(id) {
    if (confirm('Hapus aturan batas potongan matrix fee ini?')) {
        await makePostRequest('/api/admin/delete_fee_matrix', { fee_id: id }, 'Rule Fee dihapus!');
    }
}

async function updateWalletAddress(tokenKey) {
    const safeId = 'wallet-input-' + tokenKey.replace(/ /g, "-").replace(/_/g, "-");
    const addressValue = document.getElementById(safeId).value;
    
    await makePostRequest('/api/admin/update_wallet', { 
        token: tokenKey, 
        address: addressValue 
    }, `Alamat wallet gateway ${tokenKey} diperbarui!`);
}

async function addNewCryptoWallet(e) {
    e.preventDefault();
    const formData = new FormData(e.target);
    const payload = Object.fromEntries(formData.entries());
    await makePostRequest('/api/admin/add_crypto_asset', payload, 'Jaringan aset kripto baru sukses didaftarkan!');
}

async function removeCryptoAsset(tokenKey) {
    if (confirm(`Hapus koin/token ${tokenKey} dari metode pembayaran deposit crypto?`)) {
        await makePostRequest('/api/admin/delete_crypto_asset', { token: tokenKey }, `${tokenKey} berhasil dihapus!`);
    }
}
</script>
{% endblock %}
