<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - DavaOFC</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: #0A0A1A;
            color: #fff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(ellipse at 20% 50%, rgba(108,60,225,0.15) 0%, transparent 60%),
                        radial-gradient(ellipse at 80% 50%, rgba(255,107,107,0.08) 0%, transparent 60%),
                        #0A0A1A;
        }
        .login-box {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 48px 40px;
            width: 420px;
            max-width: 95%;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
            max-height: 95vh;
            overflow-y: auto;
        }
        .login-box::-webkit-scrollbar { width: 4px; }
        .login-box::-webkit-scrollbar-thumb { background: #6C3CE1; border-radius: 10px; }
        .login-box .logo { text-align: center; margin-bottom: 24px; }
        .login-box .logo h1 {
            font-size: 32px;
            font-weight: 800;
            background: linear-gradient(135deg, #fff, #8B6BE8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .login-box .logo p {
            color: rgba(255,255,255,0.5);
            font-size: 14px;
        }
        .form-group { margin-bottom: 14px; }
        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: rgba(255,255,255,0.7);
            margin-bottom: 5px;
        }
        .form-group input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
        }
        .form-group input:focus {
            outline: none;
            border-color: #6C3CE1;
            box-shadow: 0 0 0 4px rgba(108,60,225,0.1);
        }
        .form-group input::placeholder { color: rgba(255,255,255,0.3); }
        .btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none !important; }
        .btn-login {
            background: linear-gradient(135deg, #6C3CE1, #5A2DBF);
            color: #fff;
            box-shadow: 0 4px 20px rgba(108,60,225,0.3);
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 40px rgba(108,60,225,0.4);
        }
        .btn-register {
            background: linear-gradient(135deg, #00C853, #009624);
            color: #fff;
            box-shadow: 0 4px 20px rgba(0,200,83,0.3);
        }
        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 40px rgba(0,200,83,0.4);
        }
        .btn-cancel {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .btn-cancel:hover { background: rgba(255,255,255,0.2); }
        .alert {
            padding: 10px 14px;
            border-radius: 10px;
            font-size: 13px;
            margin-bottom: 14px;
            text-align: center;
        }
        .alert-error {
            background: rgba(255,23,68,0.15);
            border: 1px solid rgba(255,23,68,0.2);
            color: #FF1744;
        }
        .alert-success {
            background: rgba(0,200,83,0.15);
            border: 1px solid rgba(0,200,83,0.2);
            color: #00C853;
        }
        .divider {
            display: flex;
            align-items: center;
            margin: 16px 0;
            color: rgba(255,255,255,0.2);
            font-size: 12px;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .divider::before { margin-right: 12px; }
        .divider::after { margin-left: 12px; }
        #registerForm {
            display: none;
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid rgba(255,255,255,0.06);
        }
        .btn-group { display: flex; gap: 10px; margin-top: 4px; }
        .btn-group .btn { flex: 1; }
        .footer {
            text-align: center;
            margin-top: 20px;
            color: rgba(255,255,255,0.3);
            font-size: 12px;
        }
        .footer a {
            color: #8B6BE8;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
        }
        .footer a:hover { text-decoration: underline; }
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .toast {
            padding: 14px 20px;
            border-radius: 12px;
            background: rgba(5,5,16,0.95);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
            color: #fff;
            font-size: 14px;
            min-width: 280px;
            animation: slideIn 0.4s ease;
        }
        .toast.success { border-left: 4px solid #00C853; }
        .toast.error { border-left: 4px solid #FF1744; }
        .toast.warning { border-left: 4px solid #FFD600; }
        .toast.info { border-left: 4px solid #6C3CE1; }
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        .spinner {
            display: inline-block;
            width: 18px;
            height: 18px;
            border: 2px solid rgba(255,255,255,0.2);
            border-top: 2px solid #fff;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        @media (max-width: 480px) {
            .login-box { padding: 30px 20px; }
            .login-box .logo h1 { font-size: 26px; }
            .btn-group { flex-direction: column; }
            .toast { min-width: auto; width: calc(100vw - 40px); }
        }
    </style>
</head>
<body>
    <div class="login-box">
        <div class="logo">
            <h1>🚀 DavaOFC</h1>
            <p>Crypto Exchange & Slot Games</p>
        </div>
        
        <!-- Alert -->
        <div id="alertContainer"></div>
        
        <!-- FORM LOGIN -->
        <form id="loginForm">
            <div class="form-group">
                <label><i class="fas fa-user"></i> Telegram ID</label>
                <input type="text" id="loginId" placeholder="Masukkan ID Telegram Anda" required>
                <small style="color: rgba(255,255,255,0.3); font-size: 11px;">
                    💡 Dapatkan ID dari <b>@userinfobot</b> di Telegram
                </small>
            </div>
            <button type="submit" class="btn btn-login" id="loginBtn">
                <i class="fas fa-sign-in-alt"></i> Login
            </button>
        </form>
        
        <div class="divider">atau</div>
        
        <!-- TOMBOL REGISTER -->
        <button class="btn btn-register" onclick="showRegister()">
            <i class="fas fa-user-plus"></i> Daftar Akun Baru
        </button>
        
        <!-- FORM REGISTER (Hidden) -->
        <div id="registerForm">
            <div class="form-group">
                <label><i class="fas fa-id-card"></i> Telegram ID</label>
                <input type="text" id="regId" placeholder="Masukkan ID Telegram Anda" required>
            </div>
            <div class="form-group">
                <label><i class="fas fa-at"></i> Username</label>
                <input type="text" id="regUsername" placeholder="Username Telegram (tanpa @)" required>
            </div>
            <div class="form-group">
                <label><i class="fas fa-user"></i> Nama Lengkap</label>
                <input type="text" id="regName" placeholder="Nama Lengkap Anda" required>
            </div>
            <div class="btn-group">
                <button class="btn btn-register" onclick="registerUser()" id="registerBtn">
                    <i class="fas fa-check"></i> Daftar
                </button>
                <button class="btn btn-cancel" onclick="hideRegister()">
                    <i class="fas fa-times"></i> Batal
                </button>
            </div>
        </div>
        
        <div class="footer">
            <p>💡 Butuh bantuan? Hubungi <a href="https://t.me/davaofc4">@davaofc4</a></p>
        </div>
    </div>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        // ================= TOAST =================
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = message;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 400);
            }, 5000);
        }

        function showAlert(message, type = 'error') {
            const container = document.getElementById('alertContainer');
            container.innerHTML = `<div class="alert alert-${type}">${message}</div>`;
            setTimeout(() => { container.innerHTML = ''; }, 8000);
        }

        // ================= SHOW/HIDE REGISTER =================
        function showRegister() {
            document.getElementById('registerForm').style.display = 'block';
            document.getElementById('registerForm').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function hideRegister() {
            document.getElementById('registerForm').style.display = 'none';
            document.getElementById('regId').value = '';
            document.getElementById('regUsername').value = '';
            document.getElementById('regName').value = '';
            document.getElementById('alertContainer').innerHTML = '';
        }

        // ================= REGISTER =================
        async function registerUser() {
            const telegram_id = document.getElementById('regId').value.trim();
            const username = document.getElementById('regUsername').value.trim();
            const full_name = document.getElementById('regName').value.trim();

            if (!telegram_id || !username || !full_name) {
                showToast('⚠️ Semua field harus diisi!', 'error');
                return;
            }

            if (!/^\d+$/.test(telegram_id)) {
                showToast('⚠️ Telegram ID harus berupa angka!', 'error');
                return;
            }

            const btn = document.getElementById('registerBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span> Mendaftar...';

            try {
                const response = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ telegram_id, username, full_name })
                });

                const data = await response.json();

                if (data.success) {
                    showToast('✅ ' + data.message, 'success');
                    showAlert('✅ ' + data.message, 'success');
                    document.getElementById('loginId').value = telegram_id;
                    hideRegister();
                    setTimeout(() => {
                        document.getElementById('loginForm').dispatchEvent(new Event('submit'));
                    }, 1500);
                } else {
                    showToast('❌ ' + data.error, 'error');
                    showAlert('❌ ' + data.error, 'error');
                }
            } catch (error) {
                showToast('❌ Error: ' + error.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check"></i> Daftar';
            }
        }

        // ================= LOGIN =================
        document.getElementById('loginForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const telegram_id = document.getElementById('loginId').value.trim();
            if (!telegram_id) {
                showToast('⚠️ Masukkan Telegram ID!', 'error');
                return;
            }

            const btn = document.getElementById('loginBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span> Login...';

            try {
                const formData = new FormData();
                formData.append('telegram_id', telegram_id);

                const response = await fetch('/login', {
                    method: 'POST',
                    body: formData
                });

                if (response.redirected) {
                    window.location.href = response.url;
                } else {
                    const text = await response.text();
                    if (text.includes('User tidak ditemukan')) {
                        showToast('❌ User tidak ditemukan! Silakan daftar dulu.', 'error');
                        showAlert('❌ User tidak ditemukan! Silakan daftar akun baru.', 'error');
                        showRegister();
                    } else {
                        location.reload();
                    }
                }
            } catch (error) {
                showToast('❌ Error: ' + error.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-sign-in-alt"></i> Login';
            }
        });

        // ================= ENTER KEY =================
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                const regForm = document.getElementById('registerForm');
                if (regForm.style.display === 'block') {
                    e.preventDefault();
                    registerUser();
                }
            }
        });

        console.log('🚀 DavaOFC Login Page Ready!');
        console.log('📌 Gunakan ID dari @userinfobot');
        console.log('👑 Owner ID: 8737366854');
        console.log('🌐 Server: http://localhost:5400');
    </script>
</body>
</html>