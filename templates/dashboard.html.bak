{% extends "base.html" %}

{% block title %}Dashboard - DavaOFC{% endblock %}
{% block page_title %}Dashboard{% endblock %}

{% block content %}

<style>
/* ============================================================
   DASHBOARD ULTIMATE - 800+ BARIS
   ============================================================ */

/* ===== 1. RESET & BASE ===== */
* { margin:0; padding:0; box-sizing:border-box; }

:root {
    --primary: #6C3CE1;
    --primary-light: #8B6BE8;
    --primary-dark: #5A2DBF;
    --success: #00C853;
    --danger: #FF1744;
    --warning: #FFD600;
    --info: #00B4D8;
    --dark: #0A0A1A;
    --card: rgba(255,255,255,0.03);
    --border: rgba(255,255,255,0.05);
    --text: #FFFFFF;
    --text-secondary: rgba(255,255,255,0.5);
    --text-muted: rgba(255,255,255,0.2);
    --radius: 12px;
    --shadow: 0 8px 32px rgba(0,0,0,0.3);
}

body {
    background: var(--dark);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    padding-bottom: 80px;
    -webkit-font-smoothing: antialiased;
}

.dash-container {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 16px;
}

/* ============================================================
   🎬 ANIMASI LENGKAP
   ============================================================ */

@keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}
@keyframes slideDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
}
@keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-20px); }
    to { opacity: 1; transform: translateX(0); }
}
@keyframes slideInRight {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
}
@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}
@keyframes scaleIn {
    from { opacity: 0; transform: scale(0.85); }
    to { opacity: 1; transform: scale(1); }
}
@keyframes bounceIn {
    0% { opacity: 0; transform: scale(0.3); }
    50% { opacity: 1; transform: scale(1.05); }
    70% { transform: scale(0.95); }
    100% { transform: scale(1); }
}
@keyframes countUp {
    from { opacity: 0; transform: scale(0.5) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
}
@keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 20px rgba(108,60,225,0.1); }
    50% { box-shadow: 0 0 50px rgba(108,60,225,0.3); }
}
@keyframes pulseGlowGold {
    0%, 100% { box-shadow: 0 0 20px rgba(255,214,0,0.05); }
    50% { box-shadow: 0 0 40px rgba(255,214,0,0.2); }
}
@keyframes spinSlow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}
@keyframes shimmerText {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
}
@keyframes floatFast {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-4px); }
}
@keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(0.7); }
}
@keyframes ripple {
    0% { transform: scale(0); opacity: 0.5; }
    100% { transform: scale(4); opacity: 0; }
}
@keyframes rotateIcon {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}
@keyframes notificationSlide {
    0% { opacity: 0; transform: translateX(80px); }
    100% { opacity: 1; transform: translateX(0); }
}

/* ===== CLASS ANIMASI ===== */
.animate-slide-up { animation: slideUp 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; opacity: 0; }
.animate-slide-down { animation: slideDown 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; opacity: 0; }
.animate-slide-left { animation: slideInLeft 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; opacity: 0; }
.animate-slide-right { animation: slideInRight 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; opacity: 0; }
.animate-scale-in { animation: scaleIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; opacity: 0; }
.animate-bounce-in { animation: bounceIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; opacity: 0; }
.animate-fade-in { animation: fadeIn 0.8s ease-out forwards; opacity: 0; }
.animate-count-up { animation: countUp 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; opacity: 0; }

.delay-1 { animation-delay: 0.05s; }
.delay-2 { animation-delay: 0.10s; }
.delay-3 { animation-delay: 0.15s; }
.delay-4 { animation-delay: 0.20s; }
.delay-5 { animation-delay: 0.25s; }
.delay-6 { animation-delay: 0.30s; }
.delay-7 { animation-delay: 0.35s; }
.delay-8 { animation-delay: 0.40s; }
.delay-9 { animation-delay: 0.45s; }
.delay-10 { animation-delay: 0.50s; }
.delay-11 { animation-delay: 0.55s; }
.delay-12 { animation-delay: 0.60s; }

/* ============================================================
   DASHBOARD STYLES
   ============================================================ */

/* ===== HEADER ===== */
.dash-header {
    padding: 16px 0 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.dash-header .greeting h2 {
    font-size: 20px;
    font-weight: 700;
    background: linear-gradient(135deg, #fff, var(--primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% auto;
    animation: shimmerText 3s linear infinite;
}
.dash-header .greeting p {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 2px;
}
.dash-header .greeting p span {
    color: var(--primary-light);
    font-weight: 600;
}
.dash-header .avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 18px;
    box-shadow: 0 4px 20px rgba(108,60,225,0.3);
    position: relative;
    flex-shrink: 0;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.dash-header .avatar:hover {
    transform: scale(1.12) rotate(-5deg);
    box-shadow: 0 8px 35px rgba(108,60,225,0.5);
}
.dash-header .avatar .online-dot {
    position: absolute;
    bottom: 2px;
    right: 2px;
    width: 10px;
    height: 10px;
    background: var(--success);
    border-radius: 50%;
    border: 2px solid var(--dark);
    animation: pulseDot 2s infinite;
}

/* ===== PROMO BANNER ===== */
.promo-banner {
    background: linear-gradient(135deg, rgba(255,214,0,0.08), rgba(255,214,0,0.02));
    border: 1px solid rgba(255,214,0,0.06);
    border-radius: var(--radius);
    padding: 12px 16px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    animation: pulseGlowGold 4s ease-in-out infinite;
}
.promo-banner:hover {
    transform: translateY(-3px) scale(1.01);
    border-color: rgba(255,214,0,0.2);
}
.promo-banner .promo-text h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--warning);
}
.promo-banner .promo-text p {
    font-size: 11px;
    color: var(--text-secondary);
}
.promo-banner .promo-btn {
    background: linear-gradient(135deg, var(--warning), #f9a825);
    color: #000;
    padding: 6px 18px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 700;
    font-size: 11px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.promo-banner .promo-btn:hover {
    transform: scale(1.08) rotate(-2deg);
    box-shadow: 0 4px 20px rgba(255,214,0,0.4);
}

/* ===== BALANCE CARD ===== */
.balance-card {
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border-radius: var(--radius);
    padding: 20px 24px;
    margin-bottom: 16px;
    border: 1px solid rgba(108,60,225,0.08);
    position: relative;
    overflow: hidden;
    animation: pulseGlow 4s ease-in-out infinite;
}
.balance-card::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -10%;
    width: 180px;
    height: 180px;
    background: radial-gradient(circle, rgba(108,60,225,0.06), transparent 70%);
    border-radius: 50%;
    animation: spinSlow 30s linear infinite;
}
.balance-card::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 120px;
    height: 120px;
    background: radial-gradient(circle, rgba(255,107,107,0.04), transparent 70%);
    border-radius: 50%;
    animation: spinSlow 20s linear infinite reverse;
}
.balance-card .label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    position: relative;
    z-index: 1;
}
.balance-card .amount {
    font-size: 34px;
    font-weight: 800;
    color: #fff;
    margin: 4px 0 14px;
    position: relative;
    z-index: 1;
}
.balance-card .amount span {
    color: var(--primary-light);
    text-shadow: 0 0 40px rgba(108,60,225,0.15);
    display: inline-block;
    animation: countUp 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}
.balance-card .row {
    display: flex;
    gap: 16px;
    padding-top: 14px;
    border-top: 1px solid rgba(255,255,255,0.04);
    position: relative;
    z-index: 1;
}
.balance-card .row .item { flex: 1; text-align: center; }
.balance-card .row .item .val {
    font-size: 15px;
    font-weight: 700;
    display: inline-block;
}
.balance-card .row .item .val.green { color: var(--success); }
.balance-card .row .item .val.gold { color: var(--warning); }
.balance-card .row .item .val.red { color: var(--danger); }
.balance-card .row .item .lbl {
    font-size: 9px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 2px;
}
.balance-card .actions {
    display: flex;
    gap: 10px;
    margin-top: 14px;
    position: relative;
    z-index: 1;
}
.balance-card .actions .btn {
    flex: 1;
    padding: 10px;
    border-radius: 8px;
    border: none;
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    text-align: center;
    text-decoration: none;
    display: inline-block;
}
.balance-card .actions .btn:active { transform: scale(0.95); }
.btn-withdraw {
    background: rgba(255,23,68,0.1);
    color: var(--danger);
    border: 1px solid rgba(255,23,68,0.06);
}
.btn-withdraw:hover { 
    background: rgba(255,23,68,0.2);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(255,23,68,0.15);
}
.btn-deposit {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: #fff;
    box-shadow: 0 4px 20px rgba(108,60,225,0.25);
}
.btn-deposit:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 8px 35px rgba(108,60,225,0.4);
}

/* ===== STATS GRID ===== */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 16px;
}
.stat-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 8px;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.stat-item:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(108,60,225,0.15);
    transform: translateY(-4px) scale(1.03);
    box-shadow: 0 8px 30px rgba(108,60,225,0.05);
}
.stat-item .num {
    font-size: 20px;
    font-weight: 700;
    color: var(--primary-light);
    display: inline-block;
}
.stat-item .num.green { color: var(--success); }
.stat-item .num.gold { color: var(--warning); }
.stat-item .num.red { color: var(--danger); }
.stat-item .lbl {
    font-size: 9px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 2px;
}

/* ===== QUICK ACTIONS ===== */
.quick-actions {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    margin-bottom: 16px;
}
.quick-actions .qa-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 4px;
    text-align: center;
    text-decoration: none;
    color: var(--text-secondary);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    overflow: hidden;
}
.quick-actions .qa-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(108,60,225,0.05), transparent);
    transition: all 0.6s;
}
.quick-actions .qa-item:hover::before { left: 100%; }
.quick-actions .qa-item:hover {
    background: rgba(108,60,225,0.08);
    border-color: rgba(108,60,225,0.15);
    color: #fff;
    transform: translateY(-4px) scale(1.05);
    box-shadow: 0 8px 30px rgba(108,60,225,0.1);
}
.quick-actions .qa-item i {
    font-size: 22px;
    color: var(--primary-light);
    display: block;
    margin-bottom: 4px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.quick-actions .qa-item:hover i {
    transform: scale(1.25) rotate(5deg);
    color: #fff;
    text-shadow: 0 0 30px rgba(108,60,225,0.4);
}
.quick-actions .qa-item span {
    font-size: 9px;
    font-weight: 500;
}

/* ===== SLOT STATS ===== */
.slot-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    margin-bottom: 16px;
}
.slot-stats .slot-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.slot-stats .slot-item:hover {
    transform: translateY(-4px) scale(1.03);
    border-color: rgba(255,214,0,0.15);
    box-shadow: 0 8px 30px rgba(255,214,0,0.05);
}
.slot-stats .slot-item .num {
    font-size: 20px;
    font-weight: 700;
    color: #FFD600;
    display: inline-block;
}
.slot-stats .slot-item .lbl {
    font-size: 9px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 2px;
}

/* ===== RECENT ACTIVITY ===== */
.recent-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    margin-bottom: 16px;
}
.recent-card .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}
.recent-card .header h3 {
    font-size: 14px;
    font-weight: 600;
}
.recent-card .header h3 i {
    color: var(--primary-light);
    margin-right: 6px;
    animation: rotateIcon 10s linear infinite;
}
.recent-card .header a {
    color: var(--primary-light);
    font-size: 11px;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s;
}
.recent-card .header a:hover { 
    text-decoration: underline;
    transform: translateX(3px);
}
.recent-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,0.02);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.recent-item:last-child { border-bottom: none; }
.recent-item:hover {
    background: rgba(255,255,255,0.02);
    padding-left: 6px;
    border-radius: 6px;
}
.recent-item .left {
    display: flex;
    align-items: center;
    gap: 10px;
}
.recent-item .left .icon {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    flex-shrink: 0;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.recent-item:hover .left .icon { transform: scale(1.15) rotate(-5deg); }
.recent-item .left .icon.pending { background: rgba(255,214,0,0.1); color: var(--warning); }
.recent-item .left .icon.approved { background: rgba(0,200,83,0.1); color: var(--success); }
.recent-item .left .icon.rejected { background: rgba(255,23,68,0.1); color: var(--danger); }
.recent-item .left .icon.slot { background: rgba(108,60,225,0.1); color: var(--primary-light); }
.recent-item .left .icon.deposit { background: rgba(0,200,83,0.1); color: var(--success); }
.recent-item .left .icon.withdraw { background: rgba(255,23,68,0.1); color: var(--danger); }
.recent-item .left .info .title { font-size: 12px; font-weight: 500; }
.recent-item .left .info .time { font-size: 9px; color: var(--text-muted); }
.recent-item .right .amount {
    font-size: 13px;
    font-weight: 600;
    transition: all 0.3s;
}
.recent-item:hover .right .amount { transform: scale(1.05); }
.recent-item .right .amount.plus { color: var(--success); }
.recent-item .right .amount.minus { color: var(--danger); }
.recent-item .right .status-badge {
    font-size: 8px;
    padding: 2px 8px;
    border-radius: 10px;
    font-weight: 600;
}
.recent-item .right .status-badge.pending {
    background: rgba(255,214,0,0.1);
    color: var(--warning);
}
.recent-item .right .status-badge.approved {
    background: rgba(0,200,83,0.1);
    color: var(--success);
}
.recent-item .right .status-badge.rejected {
    background: rgba(255,23,68,0.1);
    color: var(--danger);
}

/* ===== TIPS CARD ===== */
.tips-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
    margin-bottom: 16px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.tips-card:hover {
    transform: translateY(-3px);
    border-color: rgba(108,60,225,0.1);
    box-shadow: 0 8px 30px rgba(108,60,225,0.05);
}
.tips-card .tips-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
}
.tips-card .tips-header i {
    color: var(--primary-light);
    font-size: 16px;
    animation: rotateIcon 12s linear infinite;
}
.tips-card .tips-header h4 { font-size: 13px; font-weight: 600; }
.tips-card p {
    font-size: 11px;
    color: var(--text-secondary);
    line-height: 1.5;
}
.tips-card p a {
    color: var(--primary-light);
    text-decoration: none;
    transition: all 0.3s;
}
.tips-card p a:hover { 
    text-decoration: underline;
    color: #fff;
}

/* ===== FOOTER ===== */
.dash-footer {
    text-align: center;
    padding: 16px 0 8px;
    color: var(--text-muted);
    font-size: 10px;
}
.dash-footer span { color: var(--primary-light); }

/* ===== BOTTOM NAV ===== */
.bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 6px 8px 14px;
    background: rgba(10,10,26,0.95);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255,255,255,0.04);
    z-index: 100;
}
.bottom-nav .nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: rgba(255,255,255,0.2);
    text-decoration: none;
    font-size: 8px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    padding: 2px 6px;
    border-radius: 8px;
    min-width: 36px;
    position: relative;
}
.bottom-nav .nav-item i {
    font-size: 18px;
    margin-bottom: 1px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.bottom-nav .nav-item:hover { 
    color: #fff;
    transform: translateY(-3px);
}
.bottom-nav .nav-item:hover i { transform: scale(1.2); }
.bottom-nav .nav-item.active {
    color: var(--primary-light);
}
.bottom-nav .nav-item.active i {
    text-shadow: 0 0 30px rgba(108,60,225,0.4);
    animation: floatFast 2s ease-in-out infinite;
}
.bottom-nav .nav-item .label {
    font-size: 7px;
    white-space: nowrap;
}
.bottom-nav .nav-item .badge-dot {
    position: absolute;
    top: 0;
    right: 2px;
    width: 6px;
    height: 6px;
    background: var(--danger);
    border-radius: 50%;
    animation: pulseDot 1.5s infinite;
}
.bottom-nav .nav-item.more { position: relative; }
.bottom-nav .nav-item.more .more-menu {
    display: none;
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(10,10,26,0.98);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    padding: 4px 0;
    min-width: 100px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.6);
}
.bottom-nav .nav-item.more:hover .more-menu,
.bottom-nav .nav-item.more.active .more-menu { display: block; }
.bottom-nav .nav-item.more .more-menu a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 14px;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    font-size: 11px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.bottom-nav .nav-item.more .more-menu a:hover {
    background: rgba(108,60,225,0.08);
    color: #fff;
    transform: translateX(4px);
}
.bottom-nav .nav-item.more .more-menu a i {
    font-size: 13px;
    width: 18px;
    text-align: center;
}

/* ===== MOBILE RESPONSIVE ===== */
@media (max-width: 480px) {
    .bottom-nav .nav-item { min-width: 28px; padding: 2px 4px; }
    .bottom-nav .nav-item i { font-size: 15px; }
    .bottom-nav .nav-item .label { display: none; }
    .balance-card .amount { font-size: 26px; }
    .balance-card { padding: 16px 18px; }
    .stat-item .num { font-size: 16px; }
    .stats-grid { gap: 6px; }
    .quick-actions { grid-template-columns: repeat(4, 1fr); gap: 6px; }
    .quick-actions .qa-item { padding: 10px 2px; }
    .quick-actions .qa-item i { font-size: 18px; }
    .dash-header .greeting h2 { font-size: 17px; }
    .dash-header .avatar { width: 36px; height: 36px; font-size: 14px; }
    .balance-card .row .item .val { font-size: 13px; }
    .recent-item .left .info .title { font-size: 11px; }
    .recent-item .right .amount { font-size: 12px; }
}

@media (max-width: 380px) {
    .quick-actions { grid-template-columns: repeat(2, 1fr); }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .slot-stats { grid-template-columns: 1fr; }
}
</style>

<div class="dash-container">

    <!-- ===== HEADER (TANPA JAM - SUDAH ADA DI BASE.HTML) ===== -->
    <div class="dash-header animate-slide-down delay-1">
        <div class="greeting">
            <h2>Hi, {{ user.full_name or user.username }} 👋</h2>
            <p>Welcome back! <span>🚀</span></p>
        </div>
        <div class="avatar">
            {{ user.full_name[0] if user.full_name else 'U' }}
            <div class="online-dot"></div>
        </div>
    </div>

    <!-- ===== PROMO BANNER ===== -->
    <div class="promo-banner animate-slide-up delay-2">
        <div class="promo-text">
            <h4>🎉 Bonus Deposit 10%</h4>
            <p>Deposit hari ini dapat bonus!</p>
        </div>
        <a href="/deposit" class="promo-btn">Claim</a>
    </div>

    <!-- ===== BALANCE CARD ===== -->
    <div class="balance-card animate-scale-in delay-3">
        <div class="label">💳 Available Balance</div>
        <div class="amount">Rp <span>{{ "{:,.0f}".format(balance|default(0) if balance else 0).replace(',', '.') }}</span></div>
        <div class="row">
            <div class="item">
                <div class="val green animate-slide-up delay-4">{{ "{:,.0f}".format(total_deposit|default(0) if total_deposit else 0).replace(',', '.') }}</div>
                <div class="lbl">Total Deposit</div>
            </div>
            <div class="item">
                <div class="val gold animate-slide-up delay-5">{{ "{:,.0f}".format((total_deposit|default(0) or 0) * 0.05).replace(',', '.') }}</div>
                <div class="lbl">Profit</div>
            </div>
            <div class="item">
                <div class="val red animate-slide-up delay-6">{{ pending_orders|default(0) if pending_orders else 0 }}</div>
                <div class="lbl">Pending</div>
            </div>
        </div>
        <div class="actions">
            <a href="/withdraw" class="btn btn-withdraw animate-slide-left delay-7">💸 Withdraw</a>
            <a href="/deposit" class="btn btn-deposit animate-slide-right delay-7">💰 Deposit</a>
        </div>
    </div>

    <!-- ===== STATS GRID ===== -->
    <div class="stats-grid">
        <div class="stat-item animate-scale-in delay-2">
            <div class="num">{{ total_orders|default(0) if total_orders else 0 }}</div>
            <div class="lbl">Transactions</div>
        </div>
        <div class="stat-item animate-scale-in delay-3">
            <div class="num gold">{{ pending_orders|default(0) if pending_orders else 0 }}</div>
            <div class="lbl">Pending</div>
        </div>
        <div class="stat-item animate-scale-in delay-4">
            <div class="num green">{{ "{:,.0f}".format(((total_orders|default(0) or 0) / ((total_orders|default(1) or 1)) * 100) if (total_orders|default(0) or 0) > 0 else 0).replace(',', '.') }}%</div>
            <div class="lbl">Success Rate</div>
        </div>
    </div>

    <!-- ===== QUICK ACTIONS ===== -->
    <div class="quick-actions">
        <a href="/convert" class="qa-item animate-scale-in delay-1">
            <i class="fas fa-exchange-alt"></i>
            <span>Convert</span>
        </a>
        <a href="/slot" class="qa-item animate-scale-in delay-2">
            <i class="fas fa-dice"></i>
            <span>Slot</span>
        </a>
        <a href="/arisan" class="qa-item animate-scale-in delay-3">
            <i class="fas fa-users"></i>
            <span>Arisan</span>
        </a>
        <a href="/investasi" class="qa-item animate-scale-in delay-4">
            <i class="fas fa-chart-line"></i>
            <span>Investasi</span>
        </a>
        <a href="/referral" class="qa-item animate-scale-in delay-5">
            <i class="fas fa-link"></i>
            <span>Referral</span>
        </a>
        <a href="/history" class="qa-item animate-scale-in delay-6">
            <i class="fas fa-history"></i>
            <span>Riwayat</span>
        </a>
        <a href="/reviews" class="qa-item animate-scale-in delay-7">
            <i class="fas fa-star"></i>
            <span>Ulasan</span>
        </a>
        {% if session.is_owner %}
        <a href="/admin" class="qa-item animate-scale-in delay-8">
            <i class="fas fa-crown"></i>
            <span>Admin</span>
        </a>
        {% endif %}
    </div>

    <!-- ===== SLOT STATS ===== -->
    <div class="slot-stats">
        <div class="slot-item animate-slide-left delay-3">
            <div class="num">{{ total_spins|default(0) if total_spins else 0 }}</div>
            <div class="lbl">Total Spins</div>
        </div>
        <div class="slot-item animate-slide-right delay-3">
            <div class="num">{{ "{:,.0f}".format(total_wins|default(0) if total_wins else 0).replace(',', '.') }}</div>
            <div class="lbl">Total Wins</div>
        </div>
    </div>

    <!-- ===== RECENT ACTIVITY ===== -->
    <div class="recent-card animate-slide-up delay-4">
        <div class="header">
            <h3><i class="fas fa-history"></i> Recent Activity</h3>
            <a href="/history">View All →</a>
        </div>
        {% if orders %}
            {% for order in orders[:5] %}
            <div class="recent-item animate-slide-left delay-{{ loop.index }}">
                <div class="left">
                    <div class="icon {{ order.status }}">
                        {% if order.status == 'approved' %}✓{% elif order.status == 'pending' %}⏳{% else %}✕{% endif %}
                    </div>
                    <div class="info">
                        <div class="title">{{ order.order_number }}</div>
                        <div class="time">{{ order.created_at[:16] if order.created_at else '-' }}</div>
                    </div>
                </div>
                <div class="right">
                    <div class="amount {% if order.status == 'approved' %}plus{% else %}minus{% endif %}">
                        {{ "{:,.0f}".format(order.amount_idr|default(0) if order.amount_idr else 0).replace(',', '.') }}
                    </div>
                    <span class="status-badge {{ order.status }}">{{ order.status }}</span>
                </div>
            </div>
            {% endfor %}
        {% else %}
            <div class="recent-item" style="justify-content:center;padding:20px 0;color:var(--text-muted);font-size:12px;">
                <i class="fas fa-inbox" style="font-size:24px;display:block;margin-bottom:8px;opacity:0.3;"></i>
                Belum ada aktivitas 🕊️
            </div>
        {% endif %}
    </div>

    <!-- ===== TIPS CARD ===== -->
    <div class="tips-card animate-slide-up delay-5">
        <div class="tips-header">
            <i class="fas fa-lightbulb"></i>
            <h4>💡 Tips Hari Ini</h4>
        </div>
        <p>
            Ingin profit lebih? Coba fitur <a href="/investasi">Investasi</a> 
            dengan modal mulai Rp 50.000 dan dapatkan keuntungan hingga 50%!
        </p>
    </div>

    <!-- ===== FOOTER ===== -->
    <div class="dash-footer animate-fade-in delay-6">
        © 2024 <span>DavaOFC</span> — Crypto Exchange & Slot Games
    </div>

</div>

<!-- ===== BOTTOM NAV ===== -->
<nav class="bottom-nav animate-slide-up delay-6">
    <a href="/dashboard" class="nav-item active">
        <i class="fas fa-home"></i>
        <span class="label">Home</span>
    </a>
    <a href="/convert" class="nav-item">
        <i class="fas fa-exchange-alt"></i>
        <span class="label">Convert</span>
    </a>
    <a href="/deposit" class="nav-item">
        <i class="fas fa-arrow-down"></i>
        <span class="label">Deposit</span>
    </a>
    <a href="/withdraw" class="nav-item">
        <i class="fas fa-arrow-up"></i>
        <span class="label">Withdraw</span>
    </a>
    <a href="/slot" class="nav-item">
        <i class="fas fa-dice"></i>
        <span class="label">Slot</span>
        <span class="badge-dot"></span>
    </a>
    <div class="nav-item more" onclick="toggleMore(this)">
        <i class="fas fa-ellipsis-h"></i>
        <span class="label">More</span>
        <div class="more-menu">
            <a href="/arisan"><i class="fas fa-users"></i> Arisan</a>
            <a href="/investasi"><i class="fas fa-chart-line"></i> Investasi</a>
            <a href="/referral"><i class="fas fa-link"></i> Referral</a>
            <a href="/history"><i class="fas fa-history"></i> Riwayat</a>
            <a href="/reviews"><i class="fas fa-star"></i> Ulasan</a>
            {% if session.is_owner %}
            <a href="/admin"><i class="fas fa-crown"></i> Admin</a>
            {% endif %}
            <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </div>
</nav>

<!-- ===== SCRIPT ===== -->
<script>
// Toggle More Menu
function toggleMore(el) {
    el.classList.toggle('active');
    document.querySelectorAll('.nav-item.more').forEach(function(item) {
        if (item !== el) item.classList.remove('active');
    });
}

// Close More Menu on Click Outside
document.addEventListener('click', function(e) {
    if (!e.target.closest('.nav-item.more')) {
        document.querySelectorAll('.nav-item.more').forEach(function(item) {
            item.classList.remove('active');
        });
    }
});

// ===== ANIMASI COUNTER =====
document.addEventListener('DOMContentLoaded', function() {
    const counters = document.querySelectorAll('.num, .val, .amount span');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const text = el.textContent;
                const num = parseFloat(text.replace(/[^0-9.]/g, ''));
                if (!isNaN(num) && num > 0) {
                    let current = 0;
                    const increment = Math.ceil(num / 30);
                    const duration = 800;
                    const stepTime = Math.floor(duration / 30);
                    const timer = setInterval(() => {
                        current += increment;
                        if (current >= num) {
                            el.textContent = text;
                            clearInterval(timer);
                        } else {
                            el.textContent = current.toLocaleString('id-ID');
                        }
                    }, stepTime);
                }
                observer.unobserve(el);
            }
        });
    }, { threshold: 0.3 });
    counters.forEach(c => observer.observe(c));
});

// ===== SCROLL REVEAL =====
document.addEventListener('DOMContentLoaded', function() {
    const revealElements = document.querySelectorAll('.animate-slide-up, .animate-slide-left, .animate-slide-right, .animate-scale-in');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.animationPlayState = 'running';
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    revealElements.forEach(el => {
        el.style.animationPlayState = 'paused';
        observer.observe(el);
    });
});

// ===== BALANCE CARD RIPPLE EFFECT =====
document.querySelectorAll('.btn-deposit, .btn-withdraw').forEach(btn => {
    btn.addEventListener('click', function(e) {
        const ripple = document.createElement('span');
        const rect = this.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        ripple.style.cssText = `
            position: absolute;
            width: ${size}px;
            height: ${size}px;
            border-radius: 50%;
            background: rgba(255,255,255,0.2);
            transform: scale(0);
            animation: ripple 0.6s ease-out forwards;
            pointer-events: none;
            left: ${e.clientX - rect.left - size/2}px;
            top: ${e.clientY - rect.top - size/2}px;
        `;
        this.style.position = 'relative';
        this.style.overflow = 'hidden';
        this.appendChild(ripple);
        setTimeout(() => ripple.remove(), 600);
    });
});

// ===== LOADING SKELETON =====
function showSkeleton() {
    const container = document.querySelector('.dash-container');
    if (container) {
        container.style.opacity = '0.3';
        container.style.transition = 'opacity 0.3s';
        setTimeout(() => {
            container.style.opacity = '1';
        }, 500);
    }
}

// Run on load
document.addEventListener('DOMContentLoaded', function() {
    showSkeleton();
    console.log('🚀 DavaOFC Dashboard Loaded with Animations!');
});
</script>

{% endblock %}