{% extends "base.html" %}

{% block title %}Ulasan - DavaOFC{% endblock %}
{% block page_title %}⭐ Ulasan & Testimoni{% endblock %}

{% block content %}

<!-- ============================================================
     🟢 TOAST CONTAINER
     ============================================================ -->
<div id="toastContainer" style="position:fixed;top:20px;right:20px;z-index:99999;display:flex;flex-direction:column;gap:10px;max-width:380px;"></div>

<!-- ============================================================
     🟢 KONTEN UTAMA REVIEWS
     ============================================================ -->
<div class="reviews-page-wrapper">

    <!-- ===== BANNER HEADER ===== -->
    <div class="reviews-banner">
        <div class="banner-content">
            <div class="banner-icon">⭐</div>
            <div class="banner-text">
                <h1>Ulasan & Testimoni</h1>
                <p>Lihat apa kata pengguna lain tentang layanan DavaOFC</p>
            </div>
            <div class="banner-status">
                <span class="status-dot"></span>
                <span class="status-text">{{ reviews|length|default(0) }} Ulasan</span>
            </div>
        </div>
    </div>

    <!-- ===== STATS ===== -->
    <div class="reviews-stats">
        <div class="reviews-stat" data-aos="fade-up" data-aos-delay="100">
            <div class="num">{{ reviews|length|default(0) }}</div>
            <div class="lbl">📝 Total Ulasan</div>
        </div>
        <div class="reviews-stat" data-aos="fade-up" data-aos-delay="200">
            <div class="num gold" id="avgRating">0.0</div>
            <div class="lbl">⭐ Rata-rata Rating</div>
        </div>
        <div class="reviews-stat" data-aos="fade-up" data-aos-delay="300">
            <div class="num green">{{ reviews|selectattr('rating', 'equalto', 5)|list|length }}</div>
            <div class="lbl">🌟🌟🌟🌟🌟 Bintang 5</div>
        </div>
        <div class="reviews-stat" data-aos="fade-up" data-aos-delay="400">
            <div class="num purple">{{ user_review is not none }}</div>
            <div class="lbl">✅ Ulasan Anda</div>
        </div>
    </div>

    <!-- ===== MAIN GRID ===== -->
    <div class="reviews-main-grid">

        <!-- ===== LEFT: FORM ULASAN ===== -->
        <div class="review-form-card" data-aos="fade-right">
            <div class="card-header">
                <h3><i class="fas fa-pencil-alt" style="color:#8B6BE8;"></i> Beri Ulasan</h3>
                <span class="card-badge">{{ '⭐' if user_review else '✨ Baru' }}</span>
            </div>

            {% if user_review %}
                <div class="already-reviewed">
                    <div class="reviewed-icon">✅</div>
                    <div class="reviewed-text">Anda sudah memberikan ulasan!</div>
                    <div class="reviewed-rating">{{ '⭐' * user_review.rating }}</div>
                    <div class="reviewed-message">{{ user_review.review_text }}</div>
                    <div class="reviewed-date">{{ user_review.created_at[:16] if user_review.created_at else '-' }}</div>
                </div>
            {% else %}
                <form id="reviewForm" class="review-form">
                    <div class="form-group">
                        <label>
                            <i class="fas fa-star" style="color:#FFD600;"></i> Rating
                            <span class="required">*</span>
                        </label>
                        <div class="star-rating" id="starRating">
                            <span class="star" data-value="1" onclick="setRating(1)">⭐</span>
                            <span class="star" data-value="2" onclick="setRating(2)">⭐</span>
                            <span class="star" data-value="3" onclick="setRating(3)">⭐</span>
                            <span class="star" data-value="4" onclick="setRating(4)">⭐</span>
                            <span class="star active" data-value="5" onclick="setRating(5)">⭐</span>
                        </div>
                        <input type="hidden" id="ratingValue" value="5">
                        <div id="ratingLabel" style="font-size:11px;color:rgba(255,255,255,0.2);margin-top:4px;">⭐ 5 - Sangat Baik</div>
                    </div>

                    <div class="form-group">
                        <label>
                            <i class="fas fa-comment"></i> Ulasan
                            <span class="required">*</span>
                        </label>
                        <textarea id="reviewText" placeholder="Ceritakan pengalaman Anda menggunakan layanan kami..." required></textarea>
                        <div class="char-counter">
                            <span id="charCount">0</span> / 500 karakter
                        </div>
                    </div>

                    <button type="submit" class="btn-submit" id="reviewBtn">
                        <i class="fas fa-paper-plane"></i>
                        <span class="btn-text">Kirim Ulasan</span>
                        <span class="btn-shimmer"></span>
                    </button>
                    <div id="reviewResult" style="display:none;margin-top:12px;"></div>
                </form>
            {% endif %}
        </div>

        <!-- ===== RIGHT: LIST ULASAN ===== -->
        <div class="reviews-list-card" data-aos="fade-left">
            <div class="card-header">
                <h3><i class="fas fa-comments" style="color:#FFD600;"></i> Testimoni Pengguna</h3>
                <span class="card-badge">{{ reviews|length|default(0) }} Ulasan</span>
            </div>

            <div class="reviews-filter">
                <button class="filter-btn active" data-filter="all" onclick="filterReviews('all', this)">
                    <i class="fas fa-th-list"></i> Semua
                </button>
                <button class="filter-btn" data-filter="5" onclick="filterReviews(5, this)">
                    <i class="fas fa-star"></i> 5⭐
                </button>
                <button class="filter-btn" data-filter="4" onclick="filterReviews(4, this)">
                    <i class="fas fa-star"></i> 4⭐
                </button>
                <button class="filter-btn" data-filter="3" onclick="filterReviews(3, this)">
                    <i class="fas fa-star"></i> 3⭐
                </button>
                <button class="filter-btn" data-filter="2" onclick="filterReviews(2, this)">
                    <i class="fas fa-star"></i> 2⭐
                </button>
                <button class="filter-btn" data-filter="1" onclick="filterReviews(1, this)">
                    <i class="fas fa-star"></i> 1⭐
                </button>
            </div>

            <div id="reviewsList" class="reviews-list">
                {% if reviews %}
                    {% for rev in reviews %}
                    <div class="review-card" data-rating="{{ rev.rating }}" data-aos="fade-up" data-aos-delay="{{ loop.index * 30 }}">
                        <div class="review-header">
                            <div class="review-user">
                                <div class="user-avatar">
                                    {{ (rev.username or rev.full_name or '?')[0]|upper }}
                                </div>
                                <div class="user-info">
                                    <span class="user-name">@{{ rev.username or rev.full_name }}</span>
                                    <span class="user-date">{{ rev.created_at[:16] if rev.created_at else '-' }}</span>
                                </div>
                            </div>
                            <div class="review-rating">{{ '⭐' * rev.rating }}</div>
                        </div>
                        <div class="review-body">
                            <div class="review-text">{{ rev.review_text }}</div>
                            <div class="review-actions">
                                <button class="btn-like" onclick="likeReview({{ rev.id }})">
                                    <i class="fas fa-heart"></i> <span class="like-count">0</span>
                                </button>
                                <button class="btn-share" onclick="shareReview({{ rev.id }})">
                                    <i class="fas fa-share-alt"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="empty-state">
                        <div class="empty-icon">📭</div>
                        <div class="empty-title">Belum Ada Ulasan</div>
                        <div class="empty-desc">Jadilah yang pertama memberikan ulasan!</div>
                        {% if not user_review %}
                            <button class="btn btn-primary" onclick="document.querySelector('.review-form-card').scrollIntoView({behavior:'smooth'})" style="margin-top:12px;">
                                <i class="fas fa-pencil-alt"></i> Tulis Ulasan
                            </button>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

    </div>
</div>

<!-- ============================================================
     🟢 CSS - ANIMASI 1000+ BARIS
     ============================================================ -->
<style>
/* ============================================================
   ANIMASI KEYFRAMES
   ============================================================ */
@keyframes fadeInPage {
    from { opacity:0; transform:translateY(30px) scale(0.98); }
    to { opacity:1; transform:translateY(0) scale(1); }
}
@keyframes fadeInUp {
    from { opacity:0; transform:translateY(20px); }
    to { opacity:1; transform:translateY(0); }
}
@keyframes fadeInDown {
    from { opacity:0; transform:translateY(-20px); }
    to { opacity:1; transform:translateY(0); }
}
@keyframes fadeInLeft {
    from { opacity:0; transform:translateX(-20px); }
    to { opacity:1; transform:translateX(0); }
}
@keyframes fadeInRight {
    from { opacity:0; transform:translateX(20px); }
    to { opacity:1; transform:translateX(0); }
}
@keyframes slideInUp {
    from { opacity:0; transform:translateY(40px); }
    to { opacity:1; transform:translateY(0); }
}
@keyframes slideInDown {
    from { opacity:0; transform:translateY(-40px); }
    to { opacity:1; transform:translateY(0); }
}
@keyframes slideInLeft {
    from { opacity:0; transform:translateX(-40px); }
    to { opacity:1; transform:translateX(0); }
}
@keyframes slideInRight {
    from { opacity:0; transform:translateX(40px); }
    to { opacity:1; transform:translateX(0); }
}
@keyframes scaleIn {
    from { opacity:0; transform:scale(0.85); }
    to { opacity:1; transform:scale(1); }
}
@keyframes bounceIn {
    0% { opacity:0; transform:scale(0.3); }
    50% { opacity:1; transform:scale(1.05); }
    70% { transform:scale(0.95); }
    100% { transform:scale(1); }
}
@keyframes bounceInDown {
    0% { opacity:0; transform:translateY(-200px) scale(0.3); }
    50% { transform:translateY(10px) scale(1.02); }
    70% { transform:translateY(-5px) scale(0.98); }
    100% { opacity:1; transform:translateY(0) scale(1); }
}
@keyframes bounceInLeft {
    0% { opacity:0; transform:translateX(-200px) scale(0.3); }
    50% { transform:translateX(10px) scale(1.02); }
    70% { transform:translateX(-5px) scale(0.98); }
    100% { opacity:1; transform:translateX(0) scale(1); }
}
@keyframes bounceInRight {
    0% { opacity:0; transform:translateX(200px) scale(0.3); }
    50% { transform:translateX(-10px) scale(1.02); }
    70% { transform:translateX(5px) scale(0.98); }
    100% { opacity:1; transform:translateX(0) scale(1); }
}
@keyframes shake {
    0%,100% { transform:translateX(0); }
    10%,30%,50%,70%,90% { transform:translateX(-5px); }
    20%,40%,60%,80% { transform:translateX(5px); }
}
@keyframes pulse {
    0%,100% { transform:scale(1); }
    50% { transform:scale(1.05); }
}
@keyframes pulseGlow {
    0%,100% { box-shadow:0 0 20px rgba(108,60,225,0.1); }
    50% { box-shadow:0 0 60px rgba(108,60,225,0.3); }
}
@keyframes pulseDot {
    0%,100% { opacity:1; transform:scale(1); }
    50% { opacity:0.3; transform:scale(0.6); }
}
@keyframes spin {
    to { transform:rotate(360deg); }
}
@keyframes spinSlow {
    from { transform:rotate(0deg); }
    to { transform:rotate(360deg); }
}
@keyframes float {
    0%,100% { transform:translateY(0px) rotate(0deg); }
    50% { transform:translateY(-10px) rotate(3deg); }
}
@keyframes floatSlow {
    0%,100% { transform:translateY(0px); }
    50% { transform:translateY(-6px); }
}
@keyframes shimmer {
    0% { background-position:-200% center; }
    100% { background-position:200% center; }
}
@keyframes shimmerText {
    0% { background-position:-200% center; }
    100% { background-position:200% center; }
}
@keyframes shimmerBorder {
    0% { border-color:rgba(108,60,225,0.1); }
    50% { border-color:rgba(108,60,225,0.4); }
    100% { border-color:rgba(108,60,225,0.1); }
}
@keyframes glow {
    0%,100% { text-shadow:0 0 20px rgba(108,60,225,0.1); }
    50% { text-shadow:0 0 40px rgba(108,60,225,0.3); }
}
@keyframes glowPulse {
    0%,100% { box-shadow:0 0 20px rgba(108,60,225,0.1); }
    50% { box-shadow:0 0 40px rgba(108,60,225,0.3); }
}
@keyframes borderGlow {
    0%,100% { border-color:rgba(108,60,225,0.06); }
    50% { border-color:rgba(108,60,225,0.2); }
}
@keyframes rainbow {
    0% { background-position:0% 50%; }
    50% { background-position:100% 50%; }
    100% { background-position:0% 50%; }
}
@keyframes rotateIcon {
    from { transform:rotate(0deg); }
    to { transform:rotate(360deg); }
}
@keyframes wiggle {
    0%,100% { transform:rotate(0deg); }
    25% { transform:rotate(-5deg); }
    75% { transform:rotate(5deg); }
}
@keyframes tada {
    0% { transform:scale(1); }
    10%,20% { transform:scale(0.9) rotate(-3deg); }
    30%,50%,70%,90% { transform:scale(1.1) rotate(3deg); }
    40%,60%,80% { transform:scale(1.1) rotate(-3deg); }
    100% { transform:scale(1) rotate(0); }
}
@keyframes swing {
    20% { transform:rotate(15deg); }
    40% { transform:rotate(-10deg); }
    60% { transform:rotate(5deg); }
    80% { transform:rotate(-5deg); }
    100% { transform:rotate(0deg); }
}
@keyframes zoomIn {
    0% { opacity:0; transform:scale(0.6); }
    100% { opacity:1; transform:scale(1); }
}
@keyframes zoomInUp {
    0% { opacity:0; transform:scale(0.6) translateY(100px); }
    100% { opacity:1; transform:scale(1) translateY(0); }
}
@keyframes zoomInDown {
    0% { opacity:0; transform:scale(0.6) translateY(-100px); }
    100% { opacity:1; transform:scale(1) translateY(0); }
}
@keyframes zoomInLeft {
    0% { opacity:0; transform:scale(0.6) translateX(-100px); }
    100% { opacity:1; transform:scale(1) translateX(0); }
}
@keyframes zoomInRight {
    0% { opacity:0; transform:scale(0.6) translateX(100px); }
    100% { opacity:1; transform:scale(1) translateX(0); }
}
@keyframes bounce {
    0%,20%,50%,80%,100% { transform:translateY(0); }
    40% { transform:translateY(-30px); }
    60% { transform:translateY(-15px); }
}
@keyframes bounceUp {
    0%,100% { transform:translateY(0); }
    50% { transform:translateY(-20px); }
}
@keyframes bounceDown {
    0%,100% { transform:translateY(0); }
    50% { transform:translateY(20px); }
}
@keyframes rollIn {
    0% { opacity:0; transform:translateX(-100%) rotate(-120deg); }
    100% { opacity:1; transform:translateX(0) rotate(0deg); }
}
@keyframes rollOut {
    0% { opacity:1; transform:translateX(0) rotate(0deg); }
    100% { opacity:0; transform:translateX(100%) rotate(120deg); }
}
@keyframes lightSpeedIn {
    0% { opacity:0; transform:translateX(100%) skewX(-30deg); }
    60% { opacity:1; transform:translateX(-20%) skewX(30deg); }
    80% { transform:translateX(0%) skewX(-15deg); }
    100% { opacity:1; transform:translateX(0%) skewX(0deg); }
}
@keyframes lightSpeedOut {
    0% { opacity:1; transform:translateX(0%) skewX(0deg); }
    100% { opacity:0; transform:translateX(100%) skewX(-30deg); }
}
@keyframes hinge {
    0% { transform:rotate(0deg); transform-origin:top left; animation-timing-function:ease-in-out; }
    20%,60% { transform:rotate(80deg); transform-origin:top left; animation-timing-function:ease-in-out; }
    40% { transform:rotate(60deg); transform-origin:top left; animation-timing-function:ease-in-out; }
    80% { transform:rotate(60deg) translateY(0); opacity:1; transform-origin:top left; animation-timing-function:ease-in-out; }
    100% { transform:translateY(700px); opacity:0; }
}

/* ===== ANIMATION CLASSES ===== */
.animate-up { animation:fadeInUp 0.6s ease-out forwards; }
.animate-down { animation:fadeInDown 0.6s ease-out forwards; }
.animate-left { animation:fadeInLeft 0.6s ease-out forwards; }
.animate-right { animation:fadeInRight 0.6s ease-out forwards; }
.animate-scale { animation:scaleIn 0.6s ease-out forwards; }
.animate-bounce { animation:bounce 1s ease forwards; }
.animate-pulse { animation:pulse 1.5s ease-in-out infinite; }
.animate-spin { animation:spin 2s linear infinite; }
.animate-spin-slow { animation:spinSlow 10s linear infinite; }
.animate-float { animation:float 3s ease-in-out infinite; }
.animate-shimmer { animation:shimmer 3s linear infinite; background-size:200% auto; }
.animate-glow { animation:glowPulse 2s ease-in-out infinite; }
.animate-wiggle { animation:wiggle 0.5s ease-in-out infinite; }
.animate-tada { animation:tada 0.8s ease forwards; }
.animate-swing { animation:swing 0.8s ease forwards; }
.animate-zoomIn { animation:zoomIn 0.6s ease forwards; }
.animate-zoomInUp { animation:zoomInUp 0.6s ease forwards; }
.animate-zoomInDown { animation:zoomInDown 0.6s ease forwards; }
.animate-zoomInLeft { animation:zoomInLeft 0.6s ease forwards; }
.animate-zoomInRight { animation:zoomInRight 0.6s ease forwards; }
.animate-bounceIn { animation:bounceIn 0.8s ease forwards; }
.animate-bounceInDown { animation:bounceInDown 0.8s ease forwards; }
.animate-bounceInLeft { animation:bounceInLeft 0.8s ease forwards; }
.animate-bounceInRight { animation:bounceInRight 0.8s ease forwards; }
.animate-rollIn { animation:rollIn 0.8s ease forwards; }
.animate-rollOut { animation:rollOut 0.8s ease forwards; }
.animate-lightSpeedIn { animation:lightSpeedIn 0.8s ease forwards; }
.animate-lightSpeedOut { animation:lightSpeedOut 0.8s ease forwards; }
.animate-hinge { animation:hinge 2s ease forwards; }

.delay-1 { animation-delay:0.05s; }
.delay-2 { animation-delay:0.10s; }
.delay-3 { animation-delay:0.15s; }
.delay-4 { animation-delay:0.20s; }
.delay-5 { animation-delay:0.25s; }
.delay-6 { animation-delay:0.30s; }
.delay-7 { animation-delay:0.35s; }
.delay-8 { animation-delay:0.40s; }
.delay-9 { animation-delay:0.45s; }
.delay-10 { animation-delay:0.50s; }
.delay-11 { animation-delay:0.55s; }
.delay-12 { animation-delay:0.60s; }
.delay-13 { animation-delay:0.65s; }
.delay-14 { animation-delay:0.70s; }
.delay-15 { animation-delay:0.75s; }
.delay-16 { animation-delay:0.80s; }
.delay-17 { animation-delay:0.85s; }
.delay-18 { animation-delay:0.90s; }
.delay-19 { animation-delay:0.95s; }
.delay-20 { animation-delay:1.00s; }

/* ============================================================
   REVIEWS PAGE STYLES
   ============================================================ */
.reviews-page-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px 40px;
    animation: fadeInPage 0.8s ease-out forwards;
}

/* ===== BANNER ===== */
.reviews-banner {
    background: linear-gradient(135deg, rgba(255,214,0,0.06), rgba(255,214,0,0.02));
    border: 1px solid rgba(255,214,0,0.08);
    border-radius: 16px;
    padding: 24px 28px;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
    animation: pulseGlow 4s ease-in-out infinite;
}
.reviews-banner::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255,214,0,0.04), transparent 70%);
    border-radius: 50%;
    animation: spinSlow 30s linear infinite;
}
.reviews-banner::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(108,60,225,0.04), transparent 70%);
    border-radius: 50%;
    animation: spinSlow 20s linear infinite reverse;
}
.reviews-banner .banner-content {
    display: flex;
    align-items: center;
    gap: 20px;
    position: relative;
    z-index: 1;
    flex-wrap: wrap;
}
.reviews-banner .banner-icon {
    font-size: 48px;
    animation: float 3s ease-in-out infinite;
}
.reviews-banner .banner-text h1 {
    font-size: 24px;
    font-weight: 800;
    background: linear-gradient(135deg, #fff 30%, #FFD600 60%, #F9A825);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% auto;
    animation: shimmerText 3s linear infinite;
}
.reviews-banner .banner-text p {
    font-size: 14px;
    color: rgba(255,255,255,0.4);
    margin-top: 4px;
    animation: fadeInUp 0.6s ease-out 0.3s forwards;
    opacity:0;
}
.reviews-banner .banner-status {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(255,214,0,0.1);
    border: 1px solid rgba(255,214,0,0.1);
    border-radius: 50px;
    animation: pulse 2s ease-in-out infinite;
}
.reviews-banner .banner-status .status-dot {
    width: 8px;
    height: 8px;
    background: #FFD600;
    border-radius: 50%;
    animation: pulseDot 1.5s infinite;
}
.reviews-banner .banner-status .status-text {
    font-size: 12px;
    color: #FFD600;
    font-weight: 500;
}

/* ===== STATS ===== */
.reviews-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 24px;
}
.reviews-stat {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
    transition: all 0.3s;
}
.reviews-stat:hover {
    transform: translateY(-3px);
    border-color: rgba(255,214,0,0.1);
}
.reviews-stat .num {
    font-size: 24px;
    font-weight: 700;
    color: #8B6BE8;
}
.reviews-stat .num.gold { color: #FFD600; }
.reviews-stat .num.green { color: #00C853; }
.reviews-stat .num.purple { color: #8B6BE8; }
.reviews-stat .lbl {
    font-size: 10px;
    color: rgba(255,255,255,0.25);
    text-transform: uppercase;
    margin-top: 4px;
    letter-spacing: 0.3px;
}
@media (max-width: 768px) {
    .reviews-stats { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
    .reviews-stats { grid-template-columns: 1fr 1fr; }
}

/* ===== MAIN GRID ===== */
.reviews-main-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}
@media (max-width: 768px) {
    .reviews-main-grid { grid-template-columns: 1fr; }
}

/* ===== FORM CARD ===== */
.review-form-card,
.reviews-list-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 16px;
    padding: 20px;
    transition: all 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
}
.review-form-card:hover,
.reviews-list-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255,214,0,0.08);
    box-shadow: 0 8px 40px rgba(255,214,0,0.04);
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
}
.card-header h3 {
    font-size: 16px;
    font-weight: 600;
}
.card-header .card-badge {
    font-size: 10px;
    padding: 2px 12px;
    background: rgba(0,200,83,0.1);
    border: 1px solid rgba(0,200,83,0.1);
    border-radius: 12px;
    color: #00C853;
}

/* ===== ALREADY REVIEWED ===== */
.already-reviewed {
    text-align: center;
    padding: 20px;
    background: rgba(0,200,83,0.03);
    border: 1px solid rgba(0,200,83,0.08);
    border-radius: 12px;
}
.already-reviewed .reviewed-icon {
    font-size: 48px;
    margin-bottom: 8px;
}
.already-reviewed .reviewed-text {
    font-size: 16px;
    font-weight: 600;
    color: #fff;
}
.already-reviewed .reviewed-rating {
    font-size: 24px;
    color: #FFD600;
    margin: 8px 0;
}
.already-reviewed .reviewed-message {
    color: rgba(255,255,255,0.6);
    font-size: 13px;
    padding: 8px 0;
}
.already-reviewed .reviewed-date {
    font-size: 11px;
    color: rgba(255,255,255,0.2);
}

/* ===== FORM ===== */
.review-form .form-group {
    margin-bottom: 14px;
}
.review-form .form-group label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.5);
    margin-bottom: 4px;
}
.review-form .form-group label .required {
    color: #FF1744;
}
.review-form .form-group textarea {
    width: 100%;
    padding: 10px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    color: #fff;
    font-size: 13px;
    font-family: inherit;
    min-height: 100px;
    resize: vertical;
    transition: all 0.3s;
}
.review-form .form-group textarea:focus {
    outline: none;
    border-color: #6C3CE1;
    box-shadow: 0 0 0 3px rgba(108,60,225,0.1);
}
.review-form .form-group textarea::placeholder {
    color: rgba(255,255,255,0.15);
}
.review-form .form-group .char-counter {
    text-align: right;
    font-size: 10px;
    color: rgba(255,255,255,0.15);
    margin-top: 4px;
}
.review-form .form-group .char-counter .over {
    color: #FF1744;
}

/* ===== STAR RATING ===== */
.star-rating {
    display: flex;
    gap: 4px;
    font-size: 32px;
}
.star-rating .star {
    cursor: pointer;
    color: rgba(255,255,255,0.1);
    transition: all 0.3s cubic-bezier(0.175,0.885,0.32,1.275);
}
.star-rating .star:hover {
    transform: scale(1.15);
    color: rgba(255,214,0,0.4);
}
.star-rating .star.active {
    color: #FFD600;
    animation: bounceIn 0.5s ease forwards;
}
.star-rating .star.active:hover {
    transform: scale(1.15);
}

/* ===== SUBMIT BUTTON ===== */
.btn-submit {
    width: 100%;
    padding: 10px;
    background: linear-gradient(135deg, #6C3CE1, #5A2DBF);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: inherit;
}
.btn-submit .btn-shimmer {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    transition: all 0.6s;
}
.btn-submit:hover .btn-shimmer {
    left: 100%;
}
.btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(108,60,225,0.3);
}
.btn-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}
.btn-submit .loading-spinner {
    display: inline-block;
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255,255,255,0.2);
    border-top: 2px solid #fff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

/* ===== REVIEWS FILTER ===== */
.reviews-filter {
    display: flex;
    gap: 6px;
    margin-bottom: 14px;
    flex-wrap: wrap;
}
.reviews-filter .filter-btn {
    padding: 4px 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 6px;
    color: rgba(255,255,255,0.3);
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 4px;
}
.reviews-filter .filter-btn:hover {
    background: rgba(255,255,255,0.06);
    color: #fff;
}
.reviews-filter .filter-btn.active {
    background: rgba(255,214,0,0.12);
    border-color: rgba(255,214,0,0.2);
    color: #FFD600;
}

/* ===== REVIEWS LIST ===== */
.reviews-list {
    max-height: 500px;
    overflow-y: auto;
    padding-right: 4px;
}
.reviews-list::-webkit-scrollbar { width: 3px; }
.reviews-list::-webkit-scrollbar-thumb { background: linear-gradient(135deg,#FFD600,#F9A825); border-radius: 10px; }

.review-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 12px;
    padding: 14px;
    margin-bottom: 10px;
    transition: all 0.3s;
    animation: fadeIn 0.4s ease-out forwards;
    opacity:0;
}
.review-card:nth-child(1) { animation-delay:0.02s; }
.review-card:nth-child(2) { animation-delay:0.04s; }
.review-card:nth-child(3) { animation-delay:0.06s; }
.review-card:nth-child(4) { animation-delay:0.08s; }
.review-card:nth-child(5) { animation-delay:0.10s; }
.review-card:nth-child(6) { animation-delay:0.12s; }
.review-card:nth-child(7) { animation-delay:0.14s; }
.review-card:nth-child(8) { animation-delay:0.16s; }
.review-card:nth-child(9) { animation-delay:0.18s; }
.review-card:nth-child(10) { animation-delay:0.20s; }

.review-card:hover {
    border-color: rgba(255,214,0,0.1);
    transform: translateX(4px);
}
.review-card.hidden {
    display: none;
}

.review-card .review-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}
.review-card .review-header .review-user {
    display: flex;
    align-items: center;
    gap: 10px;
}
.review-card .review-header .review-user .user-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6C3CE1, #5A2DBF);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    color: #fff;
    flex-shrink: 0;
}
.review-card .review-header .review-user .user-info .user-name {
    font-size: 13px;
    font-weight: 500;
    color: #fff;
}
.review-card .review-header .review-user .user-info .user-date {
    font-size: 10px;
    color: rgba(255,255,255,0.2);
}
.review-card .review-header .review-rating {
    color: #FFD600;
    font-size: 16px;
}

.review-card .review-body .review-text {
    color: rgba(255,255,255,0.6);
    font-size: 13px;
    line-height: 1.6;
}
.review-card .review-body .review-actions {
    display: flex;
    gap: 12px;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.03);
}
.review-card .review-body .review-actions .btn-like {
    background: none;
    border: none;
    color: rgba(255,255,255,0.3);
    cursor: pointer;
    font-size: 12px;
    font-family: inherit;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    gap: 4px;
}
.review-card .review-body .review-actions .btn-like:hover {
    color: #FF1744;
}
.review-card .review-body .review-actions .btn-like.liked {
    color: #FF1744;
}
.review-card .review-body .review-actions .btn-share {
    background: none;
    border: none;
    color: rgba(255,255,255,0.3);
    cursor: pointer;
    font-size: 12px;
    font-family: inherit;
    transition: all 0.3s;
}
.review-card .review-body .review-actions .btn-share:hover {
    color: #8B6BE8;
}

/* ===== EMPTY STATE ===== */
.empty-state {
    text-align: center;
    padding: 30px 20px;
}
.empty-state .empty-icon {
    font-size: 48px;
    margin-bottom: 12px;
    opacity: 0.3;
}
.empty-state .empty-title {
    font-size: 16px;
    font-weight: 600;
    color: rgba(255,255,255,0.3);
}
.empty-state .empty-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.15);
    margin-top: 4px;
}
.empty-state .btn-primary {
    background: linear-gradient(135deg, #6C3CE1, #5A2DBF);
    color: #fff;
    border: none;
    padding: 8px 20px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    font-family: inherit;
}
.empty-state .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(108,60,225,0.3);
}

/* ============================================================
   TOAST
   ============================================================ */
.toast {
    padding: 12px 18px;
    border-radius: 10px;
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    box-shadow: 0 8px 35px rgba(0,0,0,0.4);
    animation: slideInRight 0.4s cubic-bezier(0.175,0.885,0.32,1.275) forwards;
    backdrop-filter: blur(10px);
}
.toast.success { 
    background: linear-gradient(135deg, #00C853, #009624);
    border-left: 4px solid #69F0AE;
}
.toast.error { 
    background: linear-gradient(135deg, #FF1744, #D50000);
    border-left: 4px solid #FF8A80;
}
.toast.info { 
    background: linear-gradient(135deg, #00B4D8, #0096C7);
    border-left: 4px solid #80DEEA;
}
.toast.warning { 
    background: linear-gradient(135deg, #FFD600, #F9A825);
    color: #000;
    border-left: 4px solid #FFF59D;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 768px) {
    .reviews-banner .banner-content {
        flex-direction: column;
        text-align: center;
    }
    .reviews-banner .banner-status { margin-left: 0; }
    .reviews-banner .banner-icon { font-size: 36px; }
    .reviews-banner .banner-text h1 { font-size: 20px; }
    .reviews-banner { padding: 18px 16px; }
    .reviews-stats { grid-template-columns: repeat(2, 1fr); }
    .review-form-card { padding: 16px; }
    .reviews-list-card { padding: 16px; }
    .star-rating { font-size: 28px; }
    .review-card { padding: 12px; }
}

@media (max-width: 480px) {
    .reviews-stats { grid-template-columns: 1fr 1fr; }
    .reviews-filter { justify-content: center; }
    .reviews-filter .filter-btn { font-size: 10px; padding: 3px 10px; }
    .review-card .review-header { flex-direction: column; align-items: flex-start; gap: 4px; }
    .star-rating { font-size: 24px; }
    .already-reviewed .reviewed-rating { font-size: 20px; }
}
</style>

<!-- ============================================================
     🟢 JAVASCRIPT
     ============================================================ -->
<script>
// ============================================================
// RATING LABELS
// ============================================================
var ratingLabels = {
    1: '⭐ 1 - Sangat Buruk',
    2: '⭐⭐ 2 - Buruk',
    3: '⭐⭐⭐ 3 - Cukup',
    4: '⭐⭐⭐⭐ 4 - Baik',
    5: '⭐⭐⭐⭐⭐ 5 - Sangat Baik'
};

// ============================================================
// SET RATING
// ============================================================
function setRating(value) {
    document.getElementById('ratingValue').value = value;
    document.querySelectorAll('.star').forEach(function(s) {
        var val = parseInt(s.dataset.value);
        if (val <= value) {
            s.classList.add('active');
        } else {
            s.classList.remove('active');
        }
    });
    document.getElementById('ratingLabel').textContent = ratingLabels[value] || '⭐ ' + value + ' - Baik';
}

// ============================================================
// CHAR COUNTER
// ============================================================
document.addEventListener('DOMContentLoaded', function() {
    var textarea = document.getElementById('reviewText');
    var charCount = document.getElementById('charCount');
    
    if (textarea && charCount) {
        textarea.addEventListener('input', function() {
            var len = this.value.length;
            charCount.textContent = len;
            if (len > 500) {
                charCount.classList.add('over');
            } else {
                charCount.classList.remove('over');
            }
        });
    }
    
    // Calculate average rating
    var ratings = document.querySelectorAll('.review-card[data-rating]');
    var total = 0;
    ratings.forEach(function(r) {
        total += parseInt(r.dataset.rating);
    });
    if (ratings.length > 0) {
        var avg = (total / ratings.length).toFixed(1);
        document.getElementById('avgRating').textContent = avg;
    }
});

// ============================================================
// FILTER REVIEWS
// ============================================================
function filterReviews(rating, btn) {
    var cards = document.querySelectorAll('.review-card');
    var activeFilter = rating || 'all';
    
    document.querySelectorAll('.filter-btn').forEach(function(b) {
        b.classList.remove('active');
    });
    if (btn) {
        btn.classList.add('active');
    } else {
        document.querySelector('.filter-btn[data-filter="all"]').classList.add('active');
    }
    
    var visibleCount = 0;
    cards.forEach(function(card) {
        var cardRating = parseInt(card.dataset.rating) || 0;
        if (activeFilter === 'all' || cardRating === activeFilter) {
            card.classList.remove('hidden');
            visibleCount++;
        } else {
            card.classList.add('hidden');
        }
    });
    
    // Update badge count
    var badge = document.querySelector('.card-badge');
    if (badge) {
        badge.textContent = visibleCount + ' Ulasan';
    }
}

// ============================================================
// LIKE REVIEW
// ============================================================
function likeReview(id) {
    var btn = document.querySelector('.btn-like[data-id="' + id + '"]') || 
              document.querySelector('.review-card .btn-like');
    if (btn) {
        btn.classList.toggle('liked');
        var count = btn.querySelector('.like-count');
        if (count) {
            var current = parseInt(count.textContent) || 0;
            if (btn.classList.contains('liked')) {
                count.textContent = current + 1;
            } else {
                count.textContent = Math.max(0, current - 1);
            }
        }
    }
}

// ============================================================
// SHARE REVIEW
// ============================================================
function shareReview(id) {
    var url = window.location.href + '?review=' + id;
    if (navigator.share) {
        navigator.share({
            title: 'Ulasan DavaOFC',
            text: 'Lihat ulasan ini di DavaOFC!',
            url: url
        }).catch(function() {});
    } else {
        copyText(url);
    }
}

function copyText(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
            showToast('✅ Link berhasil disalin!', 'success');
        }).catch(function() { fallbackCopy(text); });
    } else {
        fallbackCopy(text);
    }
}

function fallbackCopy(text) {
    var input = document.createElement('input');
    input.value = text;
    document.body.appendChild(input);
    input.select();
    try {
        document.execCommand('copy');
        showToast('✅ Link berhasil disalin!', 'success');
    } catch (e) {
        showToast('❌ Gagal menyalin!', 'error');
    }
    document.body.removeChild(input);
}

// ============================================================
// SUBMIT REVIEW
// ============================================================
document.getElementById('reviewForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    var btn = document.getElementById('reviewBtn');
    var rating = parseInt(document.getElementById('ratingValue').value);
    var reviewText = document.getElementById('reviewText').value.trim();
    var result = document.getElementById('reviewResult');
    
    if (!reviewText || reviewText.length < 10) {
        showToast('❌ Ulasan minimal 10 karakter!', 'error');
        result.style.display = 'block';
        result.innerHTML = '<div style="padding:10px;background:rgba(255,23,68,0.1);border-radius:8px;border:1px solid #FF1744;text-align:center;font-size:13px;">❌ Ulasan minimal 10 karakter!</div>';
        return;
    }
    
    if (reviewText.length > 500) {
        showToast('❌ Ulasan maksimal 500 karakter!', 'error');
        return;
    }
    
    btn.disabled = true;
    btn.innerHTML = '<span class="loading-spinner"></span> Mengirim...';
    result.style.display = 'none';
    
    try {
        var response = await fetch('/api/reviews/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                rating: rating,
                review_text: reviewText
            })
        });
        
        var data = await response.json();
        
        if (data.success) {
            result.style.display = 'block';
            result.innerHTML = '<div style="padding:10px;background:rgba(0,200,83,0.1);border-radius:8px;border:1px solid #00C853;text-align:center;font-size:13px;">✅ ' + data.message + '</div>';
            showToast('✅ ' + data.message, 'success');
            document.getElementById('reviewText').value = '';
            document.getElementById('charCount').textContent = '0';
            setTimeout(function() { location.reload(); }, 2000);
        } else {
            result.style.display = 'block';
            result.innerHTML = '<div style="padding:10px;background:rgba(255,23,68,0.1);border-radius:8px;border:1px solid #FF1744;text-align:center;font-size:13px;">❌ ' + (data.error || 'Gagal mengirim ulasan!') + '</div>';
            showToast('❌ ' + (data.error || 'Gagal mengirim ulasan!'), 'error');
        }
    } catch (err) {
        console.error('Review error:', err);
        result.style.display = 'block';
        result.innerHTML = '<div style="padding:10px;background:rgba(255,23,68,0.1);border-radius:8px;border:1px solid #FF1744;text-align:center;font-size:13px;">❌ Gagal terhubung ke server!</div>';
        showToast('❌ Gagal terhubung ke server!', 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-paper-plane"></i> Kirim Ulasan';
    }
});

// ============================================================
// SHOW TOAST
// ============================================================
function showToast(message, type) {
    type = type || 'info';
    var container = document.getElementById('toastContainer');
    if (!container) {
        console.log(message);
        return;
    }
    var toast = document.createElement('div');
    toast.className = 'toast ' + type;
    toast.textContent = message;
    container.appendChild(toast);
    setTimeout(function() {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(100px)';
        setTimeout(function() { toast.remove(); }, 400);
    }, 4000);
}

// ============================================================
// KEYBOARD SHORTCUTS
// ============================================================
document.addEventListener('keydown', function(e) {
    if (e.ctrlKey && e.key === 'Enter') {
        e.preventDefault();
        var btn = document.getElementById('reviewBtn');
        if (btn && !btn.disabled) {
            btn.click();
        }
    }
});

// ============================================================
// LOAD
// ============================================================
document.addEventListener('DOMContentLoaded', function() {
    console.log('🚀 DavaOFC Reviews Page Loaded!');
    console.log('📅 ' + new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }));
    console.log('🕐 ' + new Date().toLocaleTimeString('id-ID'));
    console.log('⭐ ' + document.querySelectorAll('.review-card').length + ' ulasan ditampilkan!');
    console.log('🎬 ' + document.querySelectorAll('style').length + ' CSS animations loaded!');
});

console.log('✅ All systems ready!');
console.log('⭐ Reviews page is fully operational!');
</script>

{% endblock %}